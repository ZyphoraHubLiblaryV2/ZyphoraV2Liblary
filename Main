local function OpenChatWindow()
    if ChatWindow and ChatWindow.Parent then return end
    chatIsOpen = true

    local C2 = function(p, r) local u = Instance.new("UICorner"); u.CornerRadius = UDim.new(0, r or 10); u.Parent = p end
    local S2 = function(p, c, t) local u = Instance.new("UIStroke"); u.Color = c; u.Thickness = t or 1; u.Parent = p end

    ChatWindow = New("Frame", {
        Name = "ZyphoraChatWindow",
        Size = UDim2.new(0, 300, 0, 380),
        Position = UDim2.new(1, -330, 0.5, -190),
        BackgroundColor3 = T.BGSecondary,
        BorderSizePixel = 0,
        ZIndex = 60,
        Active = true,
        Draggable = true,
        Parent = ScreenGui,
    })
    C2(ChatWindow, 12)
    S2(ChatWindow, T.Accent, 1.2)

    -- Slide in dari kanan
    ChatWindow.Position = UDim2.new(1, 20, 0.5, -190)
    ChatWindow.BackgroundTransparency = 1
    TSpring(ChatWindow, { Position = UDim2.new(1, -330, 0.5, -190), BackgroundTransparency = 0 })

    -- Header
    local Header = New("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = ChatWindow,
    })
    C2(Header, 12)
    New("Frame", {
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 1, -12),
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = Header,
    })

    New("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = "рҹ•ҠпёҸ  Chat AI вҖ” ZyphoraHub",
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Header,
    })

    local CloseBtn2 = New("TextButton", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -30, 0.5, -12),
        BackgroundColor3 = T.Error,
        BackgroundTransparency = 0.3,
        Text = "Г—",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        Parent = Header,
    })
    C2(CloseBtn2, 6)
    CloseBtn2.MouseEnter:Connect(function() TFast(CloseBtn2, { BackgroundTransparency = 0 }) end)
    CloseBtn2.MouseLeave:Connect(function() TFast(CloseBtn2, { BackgroundTransparency = 0.3 }) end)
    CloseBtn2.MouseButton1Click:Connect(function()
        chatIsOpen = false
        local tw = TSlow(ChatWindow, { BackgroundTransparency = 1, Position = UDim2.new(1, 20, 0.5, -190) })
        if tw then tw.Completed:Once(function() if ChatWindow then ChatWindow:Destroy(); ChatWindow = nil end end) end
    end)

    -- Log scroll
    local LogScroll = New("ScrollingFrame", {
        Size = UDim2.new(1, -12, 1, -100),
        Position = UDim2.new(0, 6, 0, 44),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        Parent = ChatWindow,
    })

    local LogLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = LogScroll,
    })
    LogLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        LogScroll.CanvasSize = UDim2.new(0, 0, 0, LogLayout.AbsoluteContentSize.Y + 10)
        LogScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)

    -- Fungsi tambah bubble chat
    local msgOrder = 0
    local function AddBubble(text, isUser)
        msgOrder = msgOrder + 1
        local Bubble = New("Frame", {
            Name = "Bubble_" .. msgOrder,
            Size = UDim2.new(0.82, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            Position = isUser and UDim2.new(0.18, 0, 0, 0) or UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = isUser and T.Accent or T.Surface,
            BorderSizePixel = 0,
            LayoutOrder = msgOrder,
            Parent = LogScroll,
        })
        C2(Bubble, 8)
        if not isUser then S2(Bubble, T.Border, 1) end

        New("TextLabel", {
            Size = UDim2.new(1, -16, 0, 0),
            Position = UDim2.new(0, 8, 0, 6),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = isUser and Color3.fromRGB(255, 255, 255) or T.Text,
            TextSize = 10,
            Font = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            Parent = Bubble,
        })

        New("UIPadding", {
            PaddingBottom = UDim.new(0, 6),
            Parent = Bubble,
        })

        return Bubble
    end

