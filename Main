                BG=Color3.fromRGB(12,10,20), BGSecondary=Color3.fromRGB(18,15,30),
                BGTertiary=Color3.fromRGB(22,18,36), Surface=Color3.fromRGB(28,22,44),
                SurfaceHigh=Color3.fromRGB(36,28,58), SurfaceTop=Color3.fromRGB(44,34,68),
                Border=Color3.fromRGB(55,42,88), BorderLight=Color3.fromRGB(75,58,115),
                Accent=Color3.fromRGB(180,100,255), AccentBright=Color3.fromRGB(210,155,255),
                AccentDim=Color3.fromRGB(130,68,200), Text=Color3.fromRGB(248,244,255),
                TextDim=Color3.fromRGB(180,170,200), TextMuted=Color3.fromRGB(115,100,145),
            },
            ["Blue Ice"] = {
                BG=Color3.fromRGB(8,12,20), BGSecondary=Color3.fromRGB(12,18,30),
                BGTertiary=Color3.fromRGB(14,22,36), Surface=Color3.fromRGB(18,28,44),
                SurfaceHigh=Color3.fromRGB(24,36,58), SurfaceTop=Color3.fromRGB(28,42,68),
                Border=Color3.fromRGB(36,55,90), BorderLight=Color3.fromRGB(52,78,125),
                Accent=Color3.fromRGB(80,160,255), AccentBright=Color3.fromRGB(130,195,255),
                AccentDim=Color3.fromRGB(55,115,200), Text=Color3.fromRGB(238,244,255),
                TextDim=Color3.fromRGB(160,175,200), TextMuted=Color3.fromRGB(90,115,155),
            },
            ["Red Neon"] = {
                BG=Color3.fromRGB(14,8,10), BGSecondary=Color3.fromRGB(22,12,14),
                BGTertiary=Color3.fromRGB(28,14,16), Surface=Color3.fromRGB(36,18,20),
                SurfaceHigh=Color3.fromRGB(48,22,26), SurfaceTop=Color3.fromRGB(58,26,30),
                Border=Color3.fromRGB(78,32,38), BorderLight=Color3.fromRGB(110,46,54),
                Accent=Color3.fromRGB(255,80,100), AccentBright=Color3.fromRGB(255,135,150),
                AccentDim=Color3.fromRGB(200,55,72), Text=Color3.fromRGB(252,240,242),
                TextDim=Color3.fromRGB(200,170,175), TextMuted=Color3.fromRGB(155,100,110),
            },
            ["Green Matrix"] = {
                BG=Color3.fromRGB(8,14,10), BGSecondary=Color3.fromRGB(10,20,12),
                BGTertiary=Color3.fromRGB(12,24,14), Surface=Color3.fromRGB(14,30,16),
                SurfaceHigh=Color3.fromRGB(18,38,20), SurfaceTop=Color3.fromRGB(22,46,24),
                Border=Color3.fromRGB(28,60,32), BorderLight=Color3.fromRGB(40,85,45),
                Accent=Color3.fromRGB(80,220,110), AccentBright=Color3.fromRGB(130,250,155),
                AccentDim=Color3.fromRGB(55,165,78), Text=Color3.fromRGB(232,248,235),
                TextDim=Color3.fromRGB(155,195,162), TextMuted=Color3.fromRGB(88,145,100),
            },
        }

        local function ApplyPreset(name)
            local p = Presets[name]; if not p then return end
            for k,v in pairs(p) do self.Theme[k] = v end
            self:ApplyTheme()
        end

        SettingsTab:AddLabel("Preset Tema", 10723344432, "Pilih dan terapkan tema instan", false)
        local presetDrop = SettingsTab:AddDropdown("Pilih Preset", 10723344432, {"Default","Purple Dark","Blue Ice","Red Neon","Green Matrix"}, "Default", function() end)
        SettingsTab:AddButton("Terapkan Preset", 10723344432, function()
            local s = presetDrop:GetValue(); ApplyPreset(s)
            self:Notify("Tema", 'Preset "' .. s .. '" diterapkan.', "success")
        end)

        SettingsTab:AddSectionDivider("Custom Theme")
        local accentInput = SettingsTab:AddInput("Accent Color (HEX)", 10723344432, "#6C3BFF", function() end)
        local bgInput = SettingsTab:AddInput("Background Color (HEX)", 10723344432, "#08080E", function() end)

        self.SettingsRefs = { AccentBox = accentInput.Box, BackgroundBox = bgInput.Box }

        SettingsTab:AddSectionDivider("Custom Background")
        local bgLinkInput = SettingsTab:AddInput("Link/ID Background", 10723344432, "", function() end)
        SettingsTab:AddButton("Terapkan Background", 10723344432, function()
    local link = bgLinkInput:GetValue()
    local img = ParseImageLink(link)
    if not img or img == "" then
        if self._uiRefs.CustomBackground then self._uiRefs.CustomBackground.Visible = false end
        self._uiRefs._customBgActive = false  -- вң… TAMBAH INI
        self:Notify("Background", "Background custom dihapus.", "info")
        return
    end
    if self._uiRefs.CustomBackground then
        self._uiRefs.CustomBackground.Image = img
        self._uiRefs.CustomBackground.Visible = true
    end
    self._uiRefs._customBgActive = true  -- вң… TAMBAH INI
    self:Notify("Background", "Background custom diterapkan.", "success")
end)

        SettingsTab:AddButton("Reset Default", 10723344432, function()
            ApplyPreset("Default"); presetDrop:SetValue("Default", false)
            if self.SettingsRefs.AccentBox then self.SettingsRefs.AccentBox.Text = "#6C3BFF" end
            if self.SettingsRefs.BackgroundBox then self.SettingsRefs.BackgroundBox.Text = "#08080E" end
            self:Notify("Tema", "Dikembalikan ke Default.", "success")
        end)

        SettingsTab:AddButton("Hapus Background", 10723344432, function()
    bgLinkInput.Box.Text = ""
    if self._uiRefs.CustomBackground then self._uiRefs.CustomBackground.Visible = false end
    if self._uiRefs.CustomBackgroundGradient then self._uiRefs.CustomBackgroundGradient.Visible = false end
    if gradToggle and gradToggle.SetValue then gradToggle:SetValue(false) end
    self._uiRefs._customBgActive = false  -- вң… TAMBAH INI
    self:Notify("Background", "Background direset.", "success")
end)

        local gradToggle = SettingsTab:AddToggle("Gradasi Merah ke Biru", 10723344432, false, function(state)
        self._uiRefs._gradToggleState = state
            if self._uiRefs.CustomBackgroundGradient then
                self._uiRefs.CustomBackgroundGradient.Visible = state
            end
        end)
        
-- ====================================================
--  TITLE GLOW EFFECT
-- ====================================================
SettingsTab:AddSectionDivider("Title Glow")

-- Mode Glow
local glowModes = {"Pulse", "Sweep", "Glitch", "Rainbow"}  -- вҶҗ HANYA 2!
local glowDrop = SettingsTab:AddDropdown("Mode Glow", 10723344432, glowModes, self._glowMode or "Pulse", function(mode)
    self._glowMode = mode
    self:UpdateTitleGlow()
end)
self._glowDrop = glowDrop

-- Varian Glow (tetep ada)
local glowVariants = {"Normal", "Soft", "Extreme", "Neon", "Retro"}
local variantDrop = SettingsTab:AddDropdown("Varian Glow", 10723344432, glowVariants, self._glowVariant or "Normal", function(variant)
    self._glowVariant = variant
    self:UpdateTitleGlow()
end)
self._glowVariantDrop = variantDrop

-- Kecepatan
local speedSlider = SettingsTab:AddSlider("Kecepatan", 10723344432, 1, 20, self._glowSpeed * 10 or 10, function(val)
    self._glowSpeed = val / 10
    if self._glowRunning then
        self._glowRunning = false
        task.wait(0.1)
        self:StartTitleGlow()
    end
end)
self._glowSpeedSlider = speedSlider

-- Intensitas
local intensitySlider = SettingsTab:AddSlider("Intensitas", 10723344432, 1, 10, self._glowIntensity * 10 or 8, function(val)
    self._glowIntensity = val / 10
    if self._glowRunning then
        self._glowRunning = false
        task.wait(0.1)
        self:StartTitleGlow()
    end
end)
self._glowIntensitySlider = intensitySlider

-- Warna Glow
local colorInput = SettingsTab:AddInput("Warna Glow (HEX)", 10723344432, ColorToHex(self._glowColor or self.Theme.AccentBright), function(val)
    local c = HexToColor(val, self.Theme.AccentBright)
    self._glowColor = c
    if self._glowRunning then
        self._glowRunning = false
        task.wait(0.1)
        self:StartTitleGlow()
    end
end)
self._glowColorInput = colorInput

-- Reset button
SettingsTab:AddButton("вҶә Reset Title Glow", 10723344432, function()
    self._glowMode = "Pulse"
    self._glowVariant = "Normal"
    self._glowSpeed = 1.0
    self._glowIntensity = 0.8
    self._glowColor = self.Theme.AccentBright
    
    glowDrop:SetValue("Pulse", true)
    variantDrop:SetValue("Normal", true)
    speedSlider:SetValue(10, true)
    intensitySlider:SetValue(8, true)
    colorInput:SetValue(ColorToHex(self.Theme.AccentBright))
    
    if self._glowRunning then
        self._glowRunning = false
        task.wait(0.1)
        self:StartTitleGlow()
    end
    self:Notify("Title Glow", "Reset ke default.", "success")
end)

SettingsTab:AddSectionDivider("Profile Manager")
        local profileInput = SettingsTab:AddInput("Nama Profile", 10723344432, "setup_1", function() end)
        local saveDrop = SettingsTab:AddDropdown("Profile Tersimpan", 10723344432, {"Tidak ada profile"}, "Tidak ada profile", function() end)
        self.SaveDropdown = saveDrop

        -- Action buttons row
        local ActionRow = New("Frame", {
            Name = "ProfileActions",
            Size = UDim2.new(1,-4,0,34),
            BackgroundTransparency = 1,
            Parent = SettingsTab.ScrollBox,
        })
        New("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            Padding = UDim.new(0,5),
            Parent = ActionRow,
        })

        local function ActionBtn(label, color, order, cb)
            local Btn = New("TextButton", {
                LayoutOrder = order,
                Size = UDim2.new(1/3,-4,1,0),
                BackgroundColor3 = color,
                BackgroundTransparency = 0.15,
                Text = label,
                TextColor3 = Color3.fromRGB(240,240,240),
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                BorderSizePixel = 0,
                Parent = ActionRow,
            })
            Corner(Btn, 7)
            Stroke(Btn, color, 1, 0.4)
            Btn.MouseEnter:Connect(function() TFast(Btn, { BackgroundTransparency = 0 }) end)
            Btn.MouseLeave:Connect(function() TFast(Btn, { BackgroundTransparency = 0.15 }) end)
            Btn.MouseButton1Click:Connect(function()
                TFast(Btn, { BackgroundTransparency = 0.5 })
                task.wait(0.1)
                TFast(Btn, { BackgroundTransparency = 0.15 })
                pcall(cb)
            end)
        end

        ActionBtn("Simpan", T.Success, 1, function()
            local n = profileInput:GetValue()
            if n == "" or n == "setup_1" then self:Notify("Gagal", "Isi nama profile dahulu.", "warning"); return end
            self:SaveProfile(n)
        end)
        ActionBtn("Muat", T.AccentBright, 2, function()
            local s = saveDrop:GetValue()
            if not s or s == "Tidak ada profile" then self:Notify("Gagal", "Pilih profile dari dropdown.", "warning"); return end
            self:LoadProfile(s)
        end)
        ActionBtn("Hapus", T.Error, 3, function()
            local s = saveDrop:GetValue()
            if not s or s == "Tidak ada profile" then self:Notify("Gagal", "Pilih profile dari dropdown.", "warning"); return end
            self:DeleteProfile(s)
        end)

        SettingsTab:AddButton("Refresh Daftar", 10723344432, function()
            self:RefreshSaveProfiles()
            self:Notify("Profile", "Daftar diperbarui.", "success")
        end)

        self:RefreshSaveProfiles()
        self:ApplyTheme()
    end)

    return self
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  NOTIFY
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ZyphoraLibrary._notifQueue = {}
ZyphoraLibrary._activeNotifs = 0
ZyphoraLibrary._maxNotifs = 3
function ZyphoraLibrary:Notify(notifTitle, notifText, notifType, duration)
    -- Antri kalau udah max
    if self._activeNotifs >= self._maxNotifs then
        table.insert(self._notifQueue, {
            title = notifTitle, text = notifText,
            type = notifType, duration = duration
        })
        return
    end

    self._activeNotifs = (self._activeNotifs or 0) + 1
    local viewTime = duration or 3.5
    local T = self.Theme

    local typeColors = { success = T.Success, error = T.Error, warning = T.Warning }
    local accentColor = typeColors[notifType] or T.Accent

    local Box = New("Frame", {
        Name = "ZyphoraNotif",
        Size = UDim2.new(1,0,0,64),
        Position = UDim2.new(1,20,0,0),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = self.NotifHolder,
    })
    Corner(Box, 10)
    Stroke(Box, accentColor, 1, 0.2)

    local BoxGrad = New("Frame", {
        Size = UDim2.new(1,0,0.5,0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.97,
        BorderSizePixel = 0,
        Parent = Box,
    })
    Corner(BoxGrad, 10)

    local AccBar = New("Frame", {
        Size = UDim2.new(0,3,1,-16),
        Position = UDim2.new(0,0,0,8),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = Box,
    })
    Corner(AccBar, 2)

    New("ImageLabel", {
        Size = UDim2.new(0,16,0,16),
        Position = UDim2.new(0,14,0,14),
        BackgroundTransparency = 1,
        Image = ResolveIcon(10734950309) or "",
        ImageColor3 = accentColor,
        Parent = Box,
    })

    New("TextLabel", {
        Size = UDim2.new(1,-60,0,20),
        Position = UDim2.new(0,36,0,12),
        BackgroundTransparency = 1,
        Text = tostring(notifTitle),
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Box,
    })

    New("TextLabel", {
        Size = UDim2.new(1,-22,0,20),
        Position = UDim2.new(0,14,0,34),
        BackgroundTransparency = 1,
        Text = tostring(notifText),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = Box,
    })

    -- Tombol X
    local XBtn = New("TextButton", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(1,-24,0,6),
        BackgroundColor3 = T.SurfaceHigh,
        Text = "Г—",
        TextColor3 = T.TextMuted,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = Box,
    })
    Corner(XBtn, 5)
    XBtn.MouseEnter:Connect(function() TFast(XBtn, { BackgroundColor3 = T.Error, TextColor3 = Color3.fromRGB(255,255,255) }) end)
    XBtn.MouseLeave:Connect(function() TFast(XBtn, { BackgroundColor3 = T.SurfaceHigh, TextColor3 = T.TextMuted }) end)

    local function DismissNotif()
        if not Box or not Box.Parent then return end
        self._activeNotifs = math.max(0, self._activeNotifs - 1)
        local tw = TSlow(Box, { Position = UDim2.new(1,20,0,0), BackgroundTransparency = 1 })
        if tw then
            tw.Completed:Once(function()
                if Box then Box:Destroy() end
                -- Proses antrian
                if #self._notifQueue > 0 then
                    local next = table.remove(self._notifQueue, 1)
                    self:Notify(next.title, next.text, next.type, next.duration)
                end
            end)
        end
    end

    XBtn.MouseButton1Click:Connect(DismissNotif)

    local ProgBg = New("Frame", {
        Size = UDim2.new(1,0,0,2),
        Position = UDim2.new(0,0,1,-2),
        BackgroundColor3 = T.SurfaceHigh,
        BorderSizePixel = 0,
        Parent = Box,
    })
    local Prog = New("Frame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = ProgBg,
    })
    Tween(Prog, TI(viewTime, Enum.EasingStyle.Linear), { Size = UDim2.new(0,0,1,0) })

    TSpring(Box, { Position = UDim2.new(0,0,0,0) })

    task.delay(viewTime, DismissNotif)
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  SIDEBAR CATEGORY
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:AddSidebarCategory(categoryName)
    local T = self.Theme
    local collapsed = false
    local linkedTabs = {}

    local Cat = New("TextButton", {
        Name = "Cat_" .. categoryName,
        Size = UDim2.new(1,-4,0,22),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = self.Sidebar,
    })

    local CatLine = New("Frame", {
        Size = UDim2.new(1,0,0,1),
        Position = UDim2.new(0,0,0.5,0),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Cat,
    })

    local CatChip = New("Frame", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = Cat,
    })
    local CatTxt = New("TextLabel", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = " " .. string.upper(categoryName) .. " ",
        TextColor3 = T.TextMuted,
        TextSize = 8,
        Font = Enum.Font.GothamBold,
        Parent = CatChip,
    })

    local Arrow = New("TextLabel", {
        Size = UDim2.new(0,14,1,0),
        Position = UDim2.new(1,-16,0,0),
        BackgroundTransparency = 1,
        Text = "в–ҫ",
        TextColor3 = T.TextMuted,
        TextSize = 9,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Cat,
    })

    Cat.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        Arrow.Text = collapsed and "в–ё" or "в–ҫ"
        TFast(Arrow, { TextColor3 = collapsed and T.AccentBright or T.TextMuted })
        for _, btn in ipairs(linkedTabs) do
            if btn and btn.Parent then btn.Visible = not collapsed end
        end
    end)

    Cat.MouseEnter:Connect(function() TFast(CatTxt, { TextColor3 = T.Text }) end)
    Cat.MouseLeave:Connect(function() TFast(CatTxt, { TextColor3 = T.TextMuted }) end)

    local catObj = {
        Instance = Cat,
        LinkTab = function(_, btn)
            table.insert(linkedTabs, btn)
            btn.Visible = not collapsed
        end
    }
    self.Categories[categoryName] = catObj
    return catObj
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  CREATE TAB
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:CreateTab(tabName, iconId, isPinned, targetCategory)
    local T = self.Theme
    local tab = setmetatable({ Library = self, Elements = {} }, TabClass)

    local TabButton = New("TextButton", {
        Name = tabName .. "_Tab",
        BackgroundColor3 = T.Surface,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    Corner(TabButton, 7)

    -- Active indicator line (left side)
    local ActiveLine = New("Frame", {
        Name = "ActiveLine",
        Size = UDim2.new(0,3,1,-16),
        Position = UDim2.new(0,0,0,8),
        BackgroundColor3 = T.Accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = TabButton,
    })
    Corner(ActiveLine, 2)
    tab.ActiveLine = ActiveLine

    if isPinned then
        TabButton.Size = UDim2.new(0,122,0,30)
        TabButton.Position = UDim2.new(0,4,1,-36)
        TabButton.Parent = self.MainFrame
    else
        TabButton.Size = UDim2.new(1,-6,0,30)
        local n = 0
        for _,c in ipairs(self.Sidebar:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then n=n+1 end
        end
        TabButton.LayoutOrder = n + 1
        TabButton.Parent = self.Sidebar
        if targetCategory and self.Categories[targetCategory] then
            self.Categories[targetCategory]:LinkTab(TabButton)
        end
    end

    if iconId then
        local TabIcon = New("ImageLabel", {
            Name = "TabIcon",
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,12,0.5,-7),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = TabButton,
        })
        tab.Icon = TabIcon
    end

    local TabLabel = New("TextLabel", {
        Name = "TabLabel",
        Size = UDim2.new(1, iconId and -34 or -18, 1, 0),
        Position = UDim2.new(0, iconId and 32 or 10, 0, 0),
        BackgroundTransparency = 1,
        Text = tabName,
        TextColor3 = T.TextDim,
        TextSize = 11,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = TabButton,
    })
    tab.Label = TabLabel
    tab.Button = TabButton

    local ScrollBox = New("ScrollingFrame", {
        Name = tabName .. "_Scroll",
        Size = UDim2.new(1,-4,1,-2),
        Position = UDim2.new(0,2,0,1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Visible = false,
        Parent = self.ContentHolder,
    })
    tab.ScrollBox = ScrollBox

    local Layout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,5),
        Parent = ScrollBox,
    })
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        ScrollBox.CanvasSize = UDim2.new(0,0,0, Layout.AbsoluteContentSize.Y + 10)
    end)

    local function Activate()
        if not TabButton.Visible then return end
        for _, t in ipairs(self.Tabs) do
            if t.ScrollBox then t.ScrollBox.Visible = false end
            if t.Button then TFast(t.Button, { BackgroundColor3 = T.Surface }) end
            if t.Label then TFast(t.Label, { TextColor3 = T.TextDim }) end
            if t.Icon then TFast(t.Icon, { ImageColor3 = T.TextMuted }) end
            if t.ActiveLine then TFast(t.ActiveLine, { BackgroundTransparency = 1 }) end
        end
        ScrollBox.Visible = true
        TFast(TabButton, { BackgroundColor3 = T.SurfaceHigh })
        TFast(TabLabel, { TextColor3 = T.AccentBright })
        if tab.Icon then TFast(tab.Icon, { ImageColor3 = T.AccentBright }) end
        TFast(ActiveLine, { BackgroundTransparency = 0 })
        self.CurrentTab = tab
        self:RefreshCurrentSearch()
    end

    TabButton.MouseButton1Click:Connect(Activate)
    TabButton.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then TFast(TabButton, { BackgroundColor3 = T.SurfaceHigh }) end
    end)
    TabButton.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then TFast(TabButton, { BackgroundColor3 = T.Surface }) end
    end)

    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 and tabName ~= "Credits" then Activate() end
    self:ApplyTheme()
    return tab
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  ELEMENTS
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- Section Divider (used in tabs)
function TabClass:AddSectionDivider(label)
    local T = self.Library.Theme
    local Wrap = New("Frame", {
        Name = "Section_" .. label,
        Size = UDim2.new(1,-4,0,20),
        BackgroundTransparency = 1,
        Parent = self.ScrollBox,
    })
    local Line = New("Frame", {
        Size = UDim2.new(1,0,0,1),
        Position = UDim2.new(0,0,0.5,0),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Wrap,
    })
    local Chip = New("Frame", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = Wrap,
    })
    local Txt = New("TextLabel", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = "  " .. string.upper(label) .. "  ",
        TextColor3 = T.TextMuted,
        TextSize = 8,
        Font = Enum.Font.GothamBold,
        Parent = Chip,
    })
    table.insert(self.Library.ControlRegistry, { Kind = "Section", Root = Wrap, Line = Line, Txt = Txt })
    return Wrap
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  ALERT / STATUS BANNER
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function TabClass:AddAlert(alertType, message, dismissible)
    local T = self.Library.Theme

    local typeConfig = {
        success = { color = T.Success,  icon = "вң“", label = "Success" },
        error   = { color = T.Error,    icon = "вң—", label = "Error"   },
        warning = { color = T.Warning,  icon = "вҡ ", label = "Warning" },
        info    = { color = T.AccentBright, icon = "в„№", label = "Info" },
        bug     = { color = Color3.fromRGB(255, 140, 0), icon = "рҹҗӣ", label = "Bug" },
    }

    local cfg = typeConfig[alertType] or typeConfig["info"]

    local El = New("Frame", {
        Name = "Alert_" .. alertType,
        Size = UDim2.new(1,-4,0,44),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = false,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    Stroke(El, cfg.color, 1.2, 0.2)

    -- Left accent bar
    local AccBar = New("Frame", {
        Size = UDim2.new(0,3,1,-12),
        Position = UDim2.new(0,0,0,6),
        BackgroundColor3 = cfg.color,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(AccBar, 2)

    -- Subtle BG tint
    local BgTint = New("Frame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = cfg.color,
        BackgroundTransparency = 0.88,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(BgTint, 8)

    -- Icon label
    New("TextLabel", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(0,12,0.5,-10),
        BackgroundTransparency = 1,
        Text = cfg.icon,
        TextColor3 = cfg.color,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = El,
    })

    -- Type badge
    local Badge = New("Frame", {
        Size = UDim2.new(0,0,0,16),
        AutomaticSize = Enum.AutomaticSize.X,
        Position = UDim2.new(0,36,0,8),
        BackgroundColor3 = cfg.color,
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Badge, 4)
    New("TextLabel", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = " " .. string.upper(cfg.label) .. " ",
        TextColor3 = cfg.color,
        TextSize = 8,
        Font = Enum.Font.GothamBold,
        Parent = Badge,
    })

    -- Message
    New("TextLabel", {
        Size = UDim2.new(1, dismissible and -80 or -60, 0,16),
        Position = UDim2.new(0,36,0,24),
        BackgroundTransparency = 1,
        Text = tostring(message),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = El,
    })

    -- Dismiss button (opsional)
    if dismissible then
        local DismissBtn = New("TextButton", {
            Size = UDim2.new(0,22,0,22),
            Position = UDim2.new(1,-28,0.5,-11),
            BackgroundColor3 = T.SurfaceHigh,
            Text = "Г—",
            TextColor3 = T.TextMuted,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = El,
        })
        Corner(DismissBtn, 5)
        DismissBtn.MouseEnter:Connect(function()
            TFast(DismissBtn, { BackgroundColor3 = cfg.color, TextColor3 = Color3.fromRGB(255,255,255) })
        end)
        DismissBtn.MouseLeave:Connect(function()
            TFast(DismissBtn, { BackgroundColor3 = T.SurfaceHigh, TextColor3 = T.TextMuted })
        end)
        DismissBtn.MouseButton1Click:Connect(function()
            TSlow(El, { Size = UDim2.new(1,-4,0,0), BackgroundTransparency = 1 })
            task.delay(0.3, function() if El then El:Destroy() end end)
        end)
    end

    table.insert(self.Elements, { Name = message, Instance = El })
    return El
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  STEPPER
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function TabClass:AddStepper(text, iconId, min, max, default, step, callback)
    local T   = self.Library.Theme
    local val = default or min
    local stp = step or 1
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Stepper",
        Size = UDim2.new(1,-4,0,44),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0.5,-6),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 30 or 12
    New("TextLabel", {
        Size = UDim2.new(1,-xOff-120,1,0),
        Position = UDim2.new(0,xOff,0,0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    -- Container tombol
    local Controls = New("Frame", {
        Size = UDim2.new(0,110,0,30),
        Position = UDim2.new(1,-118,0.5,-15),
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Controls, 8)
    Stroke(Controls, T.Border, 1)

    -- Tombol вҲ’
    local MinusBtn = New("TextButton", {
        Size = UDim2.new(0,30,1,0),
        Position = UDim2.new(0,0,0,0),
        BackgroundColor3 = T.SurfaceHigh,
        Text = "вҲ’",
        TextColor3 = T.TextDim,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Parent = Controls,
    })
    Corner(MinusBtn, 8)

    -- Value display
    local ValDisplay = New("TextLabel", {
        Size = UDim2.new(1,-60,1,0),
        Position = UDim2.new(0,30,0,0),
        BackgroundTransparency = 1,
        Text = tostring(val),
        TextColor3 = T.AccentBright,
        TextSize = 13,
        Font = Enum.Font.GothamBlack,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Controls,
    })

    -- Tombol +
    local PlusBtn = New("TextButton", {
        Size = UDim2.new(0,30,1,0),
        Position = UDim2.new(1,-30,0,0),
        BackgroundColor3 = T.SurfaceHigh,
        Text = "+",
        TextColor3 = T.TextDim,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Parent = Controls,
    })
    Corner(PlusBtn, 8)

    local function UpdateVal(newVal)
        val = math.clamp(newVal, min, max)
        ValDisplay.Text = tostring(val)
        -- Dim tombol kalau di batas
        MinusBtn.TextColor3 = val <= min and T.TextMuted or T.Text
        PlusBtn.TextColor3  = val >= max and T.TextMuted or T.Text
        TFast(MinusBtn, { BackgroundColor3 = val <= min and T.Surface or T.SurfaceHigh })
        TFast(PlusBtn,  { BackgroundColor3 = val >= max and T.Surface or T.SurfaceHigh })
        pcall(act, val)
    end

    -- Animasi klik
    local function AnimBtn(btn)
        Tween(btn, TI(0.07), { BackgroundColor3 = T.Accent })
        task.wait(0.08)
        TFast(btn, { BackgroundColor3 = T.SurfaceHigh })
    end

    MinusBtn.MouseButton1Click:Connect(function()
        if val > min then
            task.spawn(AnimBtn, MinusBtn)
            UpdateVal(val - stp)
        end
    end)

    PlusBtn.MouseButton1Click:Connect(function()
        if val < max then
            task.spawn(AnimBtn, PlusBtn)
            UpdateVal(val + stp)
        end
    end)

    -- Hold to repeat
    local holding = false
    local function HoldRepeat(btn, dir)
        holding = true
        task.wait(0.4)
        while holding do
            UpdateVal(val + dir * stp)
            task.wait(0.08)
        end
    end

    MinusBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            task.spawn(HoldRepeat, MinusBtn, -1)
        end
    end)
    MinusBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            holding = false
        end
    end)

    PlusBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            task.spawn(HoldRepeat, PlusBtn, 1)
        end
    end)
    PlusBtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            holding = false
        end
    end)

    El.MouseEnter:Connect(function() TFast(ElStroke, { Color = T.BorderLight }) end)
    El.MouseLeave:Connect(function() TFast(ElStroke, { Color = T.Border }) end)

    UpdateVal(val)
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return val end,
        SetValue = function(v, fire)
            UpdateVal(v)
            if fire then pcall(act, val) end
        end,
    }
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  TOOLTIP
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:AttachTooltip(targetInstance, tooltipText)
    local T = self.Theme
    local ScreenGui = self.ScreenGui

    local TipFrame = New("Frame", {
        Name = "Tooltip",
        Size = UDim2.new(0,0,0,26),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = Color3.fromRGB(18,14,32),
        BorderSizePixel = 0,
        ZIndex = 99,
        Visible = false,
        Parent = ScreenGui,
    })
    Corner(TipFrame, 6)
    Stroke(TipFrame, T.Accent, 1)

    -- Arrow tip (segitiga kecil)
    local Arrow = New("Frame", {
        Size = UDim2.new(0,8,0,8),
        Position = UDim2.new(0,10,1,-4),
        BackgroundColor3 = Color3.fromRGB(18,14,32),
        BorderSizePixel = 0,
        Rotation = 45,
        ZIndex = 98,
        Parent = TipFrame,
    })
    Stroke(Arrow, T.Accent, 1)

    local TipTxt = New("TextLabel", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = "  " .. tostring(tooltipText) .. "  ",
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        ZIndex = 99,
        Parent = TipFrame,
    })

    -- Gradient subtle
    Gradient(TipFrame, {
        Color3.fromRGB(30,20,55),
        Color3.fromRGB(18,14,32),
    }, 90)

    local showConn, moveConn

    targetInstance.MouseEnter:Connect(function()
        TipFrame.Visible = true
        TipFrame.BackgroundTransparency = 1
        TipTxt.TextTransparency = 1
        TSpring(TipFrame, { BackgroundTransparency = 0 })
        TFast(TipTxt, { TextTransparency = 0 })

        moveConn = UserInputService.InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                TipFrame.Position = UDim2.new(
                    0, inp.Position.X + 12,
                    0, inp.Position.Y - 36
                )
            end
        end)
    end)

    targetInstance.MouseLeave:Connect(function()
        TFast(TipFrame, { BackgroundTransparency = 1 })
        TFast(TipTxt, { TextTransparency = 1 })
        task.delay(0.2, function()
            TipFrame.Visible = false
        end)
        if moveConn then moveConn:Disconnect(); moveConn = nil end
    end)

    return TipFrame
end

-- Label
function TabClass:AddLabel(text, iconId, subtitle, clickable)
    local T = self.Library.Theme
    local h = subtitle and 52 or 36

    local El = New("Frame", {
        Name = text .. "_Label",
        Size = UDim2.new(1,-4,0,h),
        BackgroundColor3 = T.BGSecondary,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Name = "Icon",
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,10,0, subtitle and 10 or 11),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 30 or 12
    local Title = New("TextLabel", {
        Name = "LabelTitle",
        Size = UDim2.new(1, -xOff-12, 0, subtitle and 20 or h),
        Position = UDim2.new(0, xOff, 0, subtitle and 6 or 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local Sub = nil
    if subtitle then
        Sub = New("TextLabel", {
            Name = "Sub",
            Size = UDim2.new(1, -xOff-12, 0,16),
            Position = UDim2.new(0, xOff, 0,28),
            BackgroundTransparency = 1,
            Text = subtitle,
            TextColor3 = T.TextMuted,
            TextSize = 10,
            Font = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = El,
        })
    end

    table.insert(self.Library.ControlRegistry, { Kind = "Label", Root = El, RootStroke = ElStroke, Title = Title, Sub = Sub, Icon = Icon })
    table.insert(self.Elements, { Name = text, Instance = El })
    return El
end

-- Button
function TabClass:AddButton(text, iconId, callback)
    local T   = self.Library.Theme
    local act = callback or function() end

    local El = New("TextButton", {
        Name = text .. "_Btn",
        Size = UDim2.new(1,-4,0,36),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,12,0.5,-7),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 32 or 12
    local BtnText = New("TextLabel", {
        Name = "BtnText",
        Size = UDim2.new(1, -xOff-30, 1, 0),
        Position = UDim2.new(0, xOff, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    -- Arrow indicator
    New("TextLabel", {
        Size = UDim2.new(0,16,1,0),
        Position = UDim2.new(1,-22,0,0),
        BackgroundTransparency = 1,
        Text = "вҖә",
        TextColor3 = T.TextMuted,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = El,
    })

    El.MouseEnter:Connect(function()
        TFast(El, { BackgroundColor3 = T.SurfaceHigh })
        TFast(ElStroke, { Color = T.BorderLight })
    end)
    El.MouseLeave:Connect(function()
        TFast(El, { BackgroundColor3 = T.Surface })
        TFast(ElStroke, { Color = T.Border })
    end)
    El.MouseButton1Click:Connect(function()
        Tween(El, TI(0.06), { BackgroundColor3 = T.Accent })
        task.wait(0.08)
        TFast(El, { BackgroundColor3 = T.SurfaceHigh })
        pcall(act)
    end)

    table.insert(self.Library.ControlRegistry, { Kind = "Button", Root = El, RootStroke = ElStroke, Title = BtnText, Icon = Icon, BtnText = BtnText })
    table.insert(self.Elements, { Name = text, Instance = El })
end

-- Toggle
function TabClass:AddToggle(text, iconId, defaultState, callback)
    local T    = self.Library.Theme
    local state= defaultState or false
    local act  = callback or function() end

    local El = New("TextButton", {
        Name = text .. "_Toggle",
        Size = UDim2.new(1,-4,0,38),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,12,0.5,-7),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 32 or 12
    local TText = New("TextLabel", {
        Name = "TText",
        Size = UDim2.new(1, -xOff-52, 1, 0),
        Position = UDim2.new(0, xOff, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    -- Toggle pill
    local Pill = New("Frame", {
        Name = "Pill",
        Size = UDim2.new(0,36,0,20),
        Position = UDim2.new(1,-46,0.5,-10),
        BackgroundColor3 = T.ToggleOff,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Pill, 50)
    Stroke(Pill, T.Border, 1)

    local Knob = New("Frame", {
        Name = "Knob",
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new(0,3,0.5,-7),
        BackgroundColor3 = T.TextMuted,
        BorderSizePixel = 0,
        Parent = Pill,
    })
    Corner(Knob, 50)

    local function UpdateVisual(animate)
        local targetBg    = state and T.ToggleOn or T.ToggleOff
        local targetKnob  = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
        local knobColor   = state and Color3.fromRGB(255,255,255) or T.TextMuted
        local strokeColor = state and T.Accent or T.Border
        if animate then
            TFast(Pill, { BackgroundColor3 = targetBg })
            TSpring(Knob, { Position = targetKnob })
            TFast(Knob, { BackgroundColor3 = knobColor })
            TFast(Stroke(Pill, strokeColor, 1), {})  -- re-apply stroke color
            -- Pulse the glow on activate
            if state then
                Tween(El, TI(0.12), { BackgroundColor3 = T.SurfaceTop })
                task.wait(0.12)
                TFast(El, { BackgroundColor3 = T.Surface })
            end
        else
            Pill.BackgroundColor3 = targetBg
            Knob.Position = targetKnob
            Knob.BackgroundColor3 = knobColor
        end
    end

    UpdateVisual(false)

    El.MouseEnter:Connect(function()
        TFast(El, { BackgroundColor3 = T.SurfaceHigh })
        TFast(ElStroke, { Color = T.BorderLight })
    end)
    El.MouseLeave:Connect(function()
        TFast(El, { BackgroundColor3 = T.Surface })
        TFast(ElStroke, { Color = T.Border })
    end)
    El.MouseButton1Click:Connect(function()
        state = not state
        self.Library.ToggleStates[text] = state
        UpdateVisual(true)
        pcall(act, state)
    end)

    self.Library.ToggleStates[text] = state
    self.Library.ToggleRegistry[text] = {
        SetState = function(newState, fire)
            state = newState and true or false
            self.Library.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(act, state) end
        end
    }

    table.insert(self.Library.ControlRegistry, { Kind = "Toggle", Root = El, RootStroke = ElStroke, Title = TText, Icon = Icon, TText = TText })
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return state end,
        SetValue = function(v, fire)
            state = v and true or false
            self.Library.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(act, state) end
        end
    }
end

-- Input
function TabClass:AddInput(text, iconId, placeholder, callback)
    local T   = self.Library.Theme
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Input",
        Size = UDim2.new(1,-4,0,44),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,9),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 30 or 12
    local Title = New("TextLabel", {
        Size = UDim2.new(1,-xOff-12,0,16),
        Position = UDim2.new(0,xOff,0,6),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local Box = New("TextBox", {
        Name = "InputBox",
        Size = UDim2.new(1,-xOff-12,0,16),
        Position = UDim2.new(0,xOff,0,24),
        BackgroundTransparency = 1,
        Text = "",
        PlaceholderText = tostring(placeholder or ""),
        PlaceholderColor3 = T.TextMuted,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        Parent = El,
    })

    -- Underline for input box
    local Underline = New("Frame", {
        Size = UDim2.new(1,-xOff-12,0,1),
        Position = UDim2.new(0,xOff,1,-5),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = El,
    })

    Box.Focused:Connect(function()
        TFast(ElStroke, { Color = T.Accent })
        TFast(Underline, { BackgroundColor3 = T.Accent })
    end)
    Box.FocusLost:Connect(function(enter)
        TFast(ElStroke, { Color = T.Border })
        TFast(Underline, { BackgroundColor3 = T.Border })
        pcall(act, Box.Text, enter)
    end)

    table.insert(self.Library.ControlRegistry, { Kind = "Input", Root = El, RootStroke = ElStroke, Title = Title, Icon = Icon, Box = Box })
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        Box = Box,
        GetValue = function() return Box.Text end,
        SetValue = function(v) Box.Text = tostring(v or "") end,
    }
end

-- Slider
function TabClass:AddSlider(text, iconId, min, max, default, callback)
    local T   = self.Library.Theme
    local val = default or min
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Slider",
        Size = UDim2.new(1,-4,0,54),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)

    local ElStroke = Stroke(El, T.Border, 1)

    local Label = New("TextLabel", {
        Size = UDim2.new(1,-60,0,18),
        Position = UDim2.new(0,12,0,7),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local ValLbl = New("TextLabel", {
        Size = UDim2.new(0,50,0,18),
        Position = UDim2.new(1,-58,0,7),
        BackgroundTransparency = 1,
        Text = tostring(val),
        TextColor3 = T.AccentBright,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = El,
    })

    local Track = New("Frame", {
        Name = "Track",
        Size = UDim2.new(1,-24,0,6),
        Position = UDim2.new(0,12,0,34),
        BackgroundColor3 = T.SurfaceHigh,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Track, 3)

    local Fill = New("Frame", {
        Size = UDim2.new((val-min)/(max-min),0,1,0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = Track,
    })
    Corner(Fill, 3)

    local Thumb = New("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new((val-min)/(max-min),0,0.5,-7),
        AnchorPoint = Vector2.new(0.5,0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0,
        Parent = Track,
    })

    Corner(Thumb, 50)
    Stroke(Thumb, T.Accent, 2)

    local HitBox = New("TextButton", {
        Size = UDim2.new(1,0,1,24),
        Position = UDim2.new(0,0,0,-12),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 5,
        Parent = Track,
    })

    local dragging = false

    local function SetSlider(v)
        val = math.clamp(v, min, max)

        local pct = (val-min)/(max-min)

        Fill.Size = UDim2.new(pct,0,1,0)
        Thumb.Position = UDim2.new(pct,0,0.5,-7)

        ValLbl.Text = tostring(val)

        if self.Library.SliderRegistry[text] then
    self.Library.SliderRegistry[text].Value = val
end

        pcall(act, val)
    end

    local function Update(x)
        local abs = Track.AbsolutePosition.X
        local sz  = Track.AbsoluteSize.X

        if sz <= 0 then
            return
        end

        local pct = math.clamp((x-abs)/sz, 0, 1)

        local v = math.floor(min + (max-min)*pct + 0.5)

        SetSlider(v)
    end

    HitBox.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then

            dragging = true
            Update(inp.Position.X)
        end
    end)

    HitBox.InputChanged:Connect(function(inp)
        if dragging and (
            inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch
        ) then
            Update(inp.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then
            return
        end

        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            Update(inp.Position.X)
        end
    end)

    El.MouseEnter:Connect(function()
        TFast(ElStroke, {
            Color = T.BorderLight
        })
    end)

    El.MouseLeave:Connect(function()
        TFast(ElStroke, {
            Color = T.Border
        })
    end)

    -- SAVE REGISTRY
    self.Library.SliderRegistry[text] = {
        Value = val,
        SetValue = SetSlider
    }

    table.insert(self.Library.ControlRegistry, {
        Kind = "Slider",
        Root = El,
        RootStroke = ElStroke,
        Title = Label,
        Track = Track
    })

    table.insert(self.Elements, {
        Name = text,
        Instance = El
    })

    return {
        GetValue = function()
            return val
        end,

        SetValue = SetSlider
    }
end

-- Textbox alias
function TabClass:AddTextbox(text, iconId, placeholder, callback)
    return self:AddInput(text, iconId, placeholder, callback)
end

-- Dropdown
function TabClass:AddDropdown(text, iconId, options, defaultValue, callback)
    local T      = self.Library.Theme
    local act    = callback or function() end
    local open   = false
    local list   = options or {}
    local sel    = defaultValue or (list[1] or "None")

    local Root = New("TextButton", {
        Name = text .. "_Dropdown",
        Size = UDim2.new(1,-4,0,40),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(Root, 8)
    local RootStroke = Stroke(Root, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,12),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Root,
        })
    end

    local xOff = iconId and 30 or 12
    local Lbl = New("TextLabel", {
        Size = UDim2.new(1,-xOff-30,0,16),
        Position = UDim2.new(0,xOff,0,4),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ValLbl = New("TextLabel", {
        Name = "ValLbl",
        Size = UDim2.new(1,-xOff-30,0,14),
        Position = UDim2.new(0,xOff,0,21),
        BackgroundTransparency = 1,
        Text = tostring(sel),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ArrowLbl = New("TextLabel", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(1,-26,0,10),
        BackgroundTransparency = 1,
        Text = "в–ҫ",
        TextColor3 = T.TextMuted,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Root,
    })

    -- Separator line in dropdown
    local Sep = New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,39),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Root,
    })

    -- Options container
    local OptHolder = New("Frame", {
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,40),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Root,
    })

    local OptScroll = New("ScrollingFrame", {
        Size = UDim2.new(1,-8,1,0),
        Position = UDim2.new(0,4,0,0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Parent = OptHolder,
    })

    local OptLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,3),
        Parent = OptScroll,
    })

    local function SetValue(v, fire)
        sel = tostring(v); ValLbl.Text = sel
        if fire then pcall(act, sel) end
    end

    local function Rebuild()
        for _, c in ipairs(OptScroll:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for i, opt in ipairs(list) do
            local isSel = tostring(opt) == sel
            local Btn = New("TextButton", {
                Name = "Opt" .. i,
                Size = UDim2.new(1,0,0,26),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                Parent = OptScroll,
            })
            Corner(Btn, 5)
            if isSel then Stroke(Btn, T.Accent, 1) end

            New("TextLabel", {
                Size = UDim2.new(1,-14,1,0),
                Position = UDim2.new(0,8,0,0),
                BackgroundTransparency = 1,
                Text = tostring(opt),
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Btn,
            })

            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(0,14,1,0),
                    Position = UDim2.new(1,-16,0,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = T.AccentBright,
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = Btn,
                })
            end

            Btn.MouseEnter:Connect(function() TFast(Btn, { BackgroundColor3 = T.SurfaceTop }) end)
            Btn.MouseLeave:Connect(function() TFast(Btn, { BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh }) end)
            Btn.MouseButton1Click:Connect(function()
                SetValue(opt, true)
                open = false
                TFast(Root, { Size = UDim2.new(1,-4,0,40) })
                TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
                TFast(Sep, { BackgroundTransparency = 0 })
                ArrowLbl.Text = "в–ҫ"
                Rebuild()
            end)
        end
        local h = math.min(OptLayout.AbsoluteContentSize.Y + 4, 115)
        OptScroll.CanvasSize = UDim2.new(0,0,0, OptLayout.AbsoluteContentSize.Y + 4)
        return h
    end

    Root.MouseButton1Click:Connect(function()
        open = not open
        if open then
            local h = Rebuild()
            TSpring(OptHolder, { Size = UDim2.new(1,0,0,h) })
            TSpring(Root, { Size = UDim2.new(1,-4,0,40+h+6) })
            TFast(RootStroke, { Color = T.Accent })
            ArrowLbl.Text = "в–ҙ"
        else
            TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
            TFast(Root, { Size = UDim2.new(1,-4,0,40) })
            TFast(RootStroke, { Color = T.Border })
            ArrowLbl.Text = "в–ҫ"
        end
    end)

    SetValue(sel, false)

    table.insert(self.Library.ControlRegistry, { Kind = "Dropdown", Root = Root, RootStroke = RootStroke, Title = Lbl, Icon = Icon, ValLabel = ValLbl })
    table.insert(self.Elements, { Name = text, Instance = Root })

    local api = {}
    function api:GetValue() return sel end
    function api:SetValue(v, fire) SetValue(v, fire) end
    function api:SetOptions(newOpts, newDef, fireDef)
        list = newOpts or {}
        if newDef ~= nil then SetValue(newDef, fireDef) end
        if open then Rebuild() end
    end
    return api
end

-- Multi Dropdown
function TabClass:AddMultiDropdown(text, iconId, options, defaultValues, callback)
    local T      = self.Library.Theme
    local act    = callback or function() end
    local open   = false
    local list   = options or {}
    local chosen = {}

    -- Set default values
    if defaultValues then
        for _, v in ipairs(defaultValues) do
            chosen[tostring(v)] = true
        end
    end

   local function GetSelected()
        local result = {}
        for _, opt in ipairs(list) do
            if chosen[tostring(opt)] then
                table.insert(result, tostring(opt))
            end
        end
        return result
    end

    local function GetDisplayText()
        local sel = GetSelected()
        if #sel == 0 then return "Tidak ada dipilih" end
        if #sel == 1 then return sel[1] end
        return sel[1] .. " +" .. (#sel - 1) .. " lainnya"
    end

    local Root = New("TextButton", {
        Name = text .. "_MultiDropdown",
        Size = UDim2.new(1,-4,0,40),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(Root, 8)
    local RootStroke = Stroke(Root, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,12),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Root,
        })
    end

    local xOff = iconId and 30 or 12

    local Lbl = New("TextLabel", {
        Size = UDim2.new(1,-xOff-30,0,16),
        Position = UDim2.new(0,xOff,0,4),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ValLbl = New("TextLabel", {
        Name = "ValLbl",
        Size = UDim2.new(1,-xOff-30,0,14),
        Position = UDim2.new(0,xOff,0,21),
        BackgroundTransparency = 1,
        Text = GetDisplayText(),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ArrowLbl = New("TextLabel", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(1,-26,0,10),
        BackgroundTransparency = 1,
        Text = "в–ҫ",
        TextColor3 = T.TextMuted,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Root,
    })

    -- Counter badge
    local CountBadge = New("Frame", {
        Size = UDim2.new(0,18,0,18),
        Position = UDim2.new(1,-48,0,11),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Visible = false,
        Parent = Root,
    })
    Corner(CountBadge, 50)
    local CountLbl = New("TextLabel", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        Text = "0",
        TextColor3 = Color3.fromRGB(255,255,255),
        TextSize = 9,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = CountBadge,
    })

    local Sep = New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,39),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Root,
    })

    local OptHolder = New("Frame", {
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,40),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Root,
    })

    local OptScroll = New("ScrollingFrame", {
        Size = UDim2.new(1,-8,1,0),
        Position = UDim2.new(0,4,0,0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Parent = OptHolder,
    })

    local OptLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,3),
        Parent = OptScroll,
    })

    -- Select All / Clear Row
    local CtrlRow = New("Frame", {
        Size = UDim2.new(1,-8,0,22),
        BackgroundTransparency = 1,
        Parent = OptScroll,
    })
    New("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        Padding = UDim.new(0,4),
        Parent = CtrlRow,
    })

    local function UpdateBadge()
        local sel = GetSelected()
        local count = #sel
        if count > 0 then
            CountBadge.Visible = true
            CountLbl.Text = tostring(count)
        else
            CountBadge.Visible = false
        end
        ValLbl.Text = GetDisplayText()
    end

    local function Rebuild()
        for _, c in ipairs(OptScroll:GetChildren()) do
            if c:IsA("TextButton") or (c:IsA("Frame") and c.Name ~= "CtrlRow") then
                c:Destroy()
            end
        end

        -- Select All button
        local SelAll = New("TextButton", {
            Size = UDim2.new(0.5,-2,1,0),
            BackgroundColor3 = T.SurfaceHigh,
            Text = "Pilih Semua",
            TextColor3 = T.AccentBright,
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = CtrlRow,
        })
        Corner(SelAll, 5)
        SelAll.MouseButton1Click:Connect(function()
            for _, opt in ipairs(list) do chosen[tostring(opt)] = true end
            UpdateBadge()
            Rebuild()
            pcall(act, GetSelected())
        end)

        -- Clear button
        local ClearBtn = New("TextButton", {
            Size = UDim2.new(0.5,-2,1,0),
            BackgroundColor3 = T.SurfaceHigh,
            Text = "Hapus Semua",
            TextColor3 = T.Error,
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = CtrlRow,
        })
        Corner(ClearBtn, 5)
        ClearBtn.MouseButton1Click:Connect(function()
            chosen = {}
            UpdateBadge()
            Rebuild()
            pcall(act, GetSelected())
        end)

        -- Divider
        New("Frame", {
            Size = UDim2.new(1,0,0,1),
            BackgroundColor3 = T.Border,
            BorderSizePixel = 0,
            Parent = OptScroll,
        })

        for i, opt in ipairs(list) do
            local key    = tostring(opt)
            local isSel  = chosen[key] == true

            local Row = New("TextButton", {
                Name = "Opt_" .. i,
                Size = UDim2.new(1,0,0,28),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Parent = OptScroll,
            })
            Corner(Row, 5)
            local RowStroke = Stroke(Row, isSel and T.Accent or T.Border, 1)

            -- Checkbox
            local CheckBox = New("Frame", {
                Size = UDim2.new(0,14,0,14),
                Position = UDim2.new(0,8,0.5,-7),
                BackgroundColor3 = isSel and T.Accent or T.SurfaceHigh,
                BorderSizePixel = 0,
                Parent = Row,
            })
            Corner(CheckBox, 4)
            Stroke(CheckBox, isSel and T.Accent or T.Border, 1)

            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(1,0,1,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = Color3.fromRGB(255,255,255),
                    TextSize = 9,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = CheckBox,
                })
            end

            New("TextLabel", {
                Size = UDim2.new(1,-36,1,0),
                Position = UDim2.new(0,28,0,0),
                BackgroundTransparency = 1,
                Text = key,
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Row,
            })

            Row.MouseEnter:Connect(function()
                if not chosen[key] then
                    TFast(Row, { BackgroundColor3 = T.SurfaceTop })
                    TFast(RowStroke, { Color = T.BorderLight })
                end
            end)
            Row.MouseLeave:Connect(function()
                if not chosen[key] then
                    TFast(Row, { BackgroundColor3 = T.SurfaceHigh })
                    TFast(RowStroke, { Color = T.Border })
                end
            end)
            Row.MouseButton1Click:Connect(function()
                chosen[key] = not chosen[key] or nil
                UpdateBadge()
                Rebuild()
                pcall(act, GetSelected())
            end)
        end

        local h = math.min(OptLayout.AbsoluteContentSize.Y + 4, 140)
        OptScroll.CanvasSize = UDim2.new(0,0,0, OptLayout.AbsoluteContentSize.Y + 4)
        return h
    end

    Root.MouseButton1Click:Connect(function()
        open = not open
        if open then
            local h = Rebuild()
            TSpring(OptHolder, { Size = UDim2.new(1,0,0,h) })
            TSpring(Root, { Size = UDim2.new(1,-4,0,40+h+6) })
            TFast(RootStroke, { Color = T.Accent })
            ArrowLbl.Text = "в–ҙ"
        else
            TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
            TFast(Root, { Size = UDim2.new(1,-4,0,40) })
            TFast(RootStroke, { Color = T.Border })
            ArrowLbl.Text = "в–ҫ"
        end
    end)

    UpdateBadge()

    table.insert(self.Library.ControlRegistry, { Kind = "Dropdown", Root = Root, RootStroke = RootStroke, Title = Lbl, Icon = Icon, ValLabel = ValLbl })
    table.insert(self.Elements, { Name = text, Instance = Root })

    local api = {}
    function api:GetValue() return GetSelected() end
    function api:SetValue(tbl, fire)
        chosen = {}
        if type(tbl) == "table" then
            for _, v in ipairs(tbl) do chosen[tostring(v)] = true end
        end
        UpdateBadge()
        if open then Rebuild() end
        if fire then pcall(act, GetSelected()) end
    end
    function api:SetOptions(newOpts, fire)
        list = newOpts or {}
        chosen = {}
        UpdateBadge()
        if open then Rebuild() end
        if fire then pcall(act, GetSelected()) end
    end
    return api
end

-- List
function TabClass:AddList(text, iconId, items, callback)
    local T   = self.Library.Theme
    local act = callback or function() end
    local selected = nil

    local Wrap = New("Frame", {
        Name = text .. "_List",
        Size = UDim2.new(1,-4,0,0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = false,
        Parent = self.ScrollBox,
    })
    Corner(Wrap, 8)
    local WrapStroke = Stroke(Wrap, T.Border, 1)

    -- Header
    local Header = New("Frame", {
        Name = "Header",
        Size = UDim2.new(1,0,0,32),
        BackgroundTransparency = 1,
        Parent = Wrap,
    })

    if iconId then
        New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0.5,-6),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Header,
        })
    end

    local xOff = iconId and 30 or 12
    New("TextLabel", {
        Size = UDim2.new(1,-xOff-12,1,0),
        Position = UDim2.new(0,xOff,0,0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Header,
    })

    -- Divider
    New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,31),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Wrap,
    })

    -- Items Container
    local ItemsHolder = New("Frame", {
        Name = "ItemsHolder",
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,36),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = Wrap,
    })
    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,2),
        Parent = ItemsHolder,
    })
    New("UIPadding", {
        PaddingLeft  = UDim.new(0,6),
        PaddingRight = UDim.new(0,6),
        PaddingBottom= UDim.new(0,6),
        Parent = ItemsHolder,
    })

    local itemRefs = {}

    local function BuildItems()
        for _, c in ipairs(ItemsHolder:GetChildren()) do
            if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
        end
        itemRefs = {}

        for i, item in ipairs(items or {}) do
            local isSel = tostring(item) == tostring(selected)

            local Row = New("TextButton", {
                Name = "Item_" .. i,
                Size = UDim2.new(1,0,0,28),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Parent = ItemsHolder,
            })
            Corner(Row, 6)
            local RowStroke = isSel and Stroke(Row, T.Accent, 1) or Stroke(Row, T.Border, 1)

            -- Left accent dot
            local Dot = New("Frame", {
                Size = UDim2.new(0,4,0,4),
                Position = UDim2.new(0,8,0.5,-2),
                BackgroundColor3 = isSel and T.Accent or T.TextMuted,
                BorderSizePixel = 0,
                Parent = Row,
            })
            Corner(Dot, 50)

            New("TextLabel", {
                Size = UDim2.new(1,-42,1,0),
                Position = UDim2.new(0,20,0,0),
                BackgroundTransparency = 1,
                Text = tostring(item),
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Row,
            })

            -- Checkmark kalau selected
            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(0,16,1,0),
                    Position = UDim2.new(1,-20,0,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = T.AccentBright,
                    TextSize = 11,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = Row,
                })
            end

            Row.MouseEnter:Connect(function()
                if tostring(item) ~= tostring(selected) then
                    TFast(Row, { BackgroundColor3 = T.SurfaceTop })
                    TFast(RowStroke, { Color = T.BorderLight })
                end
            end)
            Row.MouseLeave:Connect(function()
                if tostring(item) ~= tostring(selected) then
                    TFast(Row, { BackgroundColor3 = T.SurfaceHigh })
                    TFast(RowStroke, { Color = T.Border })
                end
            end)
            Row.MouseButton1Click:Connect(function()
                selected = tostring(item)
                Tween(Row, TI(0.06), { BackgroundColor3 = T.Accent })
                task.wait(0.08)
                BuildItems()
                pcall(act, selected)
            end)

            table.insert(itemRefs, Row)
        end
    end

    BuildItems()

    table.insert(self.Library.ControlRegistry, { Kind = "List", Root = Wrap, RootStroke = WrapStroke })
    table.insert(self.Elements, { Name = text, Instance = Wrap })

    return {
        GetValue    = function() return selected end,
        SetValue    = function(v, fire)
            selected = tostring(v)
            BuildItems()
            if fire then pcall(act, selected) end
        end,
        SetItems    = function(newItems, fire)
            items = newItems or {}
            selected = nil
            BuildItems()
            if fire then pcall(act, selected) end
        end,
        ClearSelect = function()
            selected = nil
            BuildItems()
        end,
    }
end

return ZyphoraLibrary
