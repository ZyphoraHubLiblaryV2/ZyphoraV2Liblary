        local function ApplyPreset(name)
            local p = Presets[name]; if not p then return end
            for k,v in pairs(p) do self.Theme[k] = v end
            self:ApplyTheme()
        end

        SettingsTab:AddLabel("Preset Tema", 10723344432, "Pilih dan terapkan tema instan", false)
        local presetDrop = SettingsTab:AddDropdown("Pilih Preset", 10723344432, {"Default","Purple Dark","Blue Ice","Red Neon","Green Matrix"}, "Default", function() end)
        SettingsTab:AddButton("Terapkan Preset", 10723344432, function()
            local s = presetDrop:GetValue(); ApplyPreset(s)
            self:Notify("Tema", 'Preset "' .. s .. '" diterapkan.', "success")
        end)

        SettingsTab:AddSectionDivider("Custom Theme")
        local accentInput = SettingsTab:AddInput("Accent Color (HEX)", 10723344432, "#6C3BFF", function() end)
        local bgInput = SettingsTab:AddInput("Background Color (HEX)", 10723344432, "#08080E", function() end)

        self.SettingsRefs = { AccentBox = accentInput.Box, BackgroundBox = bgInput.Box }

        SettingsTab:AddButton("Terapkan Custom Theme", 10723344432, function()
            local accent = HexToColor(accentInput:GetValue(), self.Theme.Accent)
            local bg = HexToColor(bgInput:GetValue(), self.Theme.BG)
            local function sh(c, f) return Color3.fromRGB(math.clamp(math.floor(c.R*255*f),0,255), math.clamp(math.floor(c.G*255*f),0,255), math.clamp(math.floor(c.B*255*f),0,255)) end
            self.Theme.Accent = accent; self.Theme.AccentBright = sh(accent,1.4); self.Theme.AccentDim = sh(accent,0.7)
            self.Theme.BG = bg; self.Theme.BGSecondary = sh(bg,1.5); self.Theme.BGTertiary = sh(bg,2)
            self.Theme.Surface = sh(bg,2.5); self.Theme.SurfaceHigh = sh(bg,3.2); self.Theme.SurfaceTop = sh(bg,3.8)
            self.Theme.Border = sh(bg,4.5); self.Theme.BorderLight = sh(bg,6.5)
            self.Theme.TextMuted = sh(bg,9)
            self:ApplyTheme()
            self:Notify("Tema Kustom", "Berhasil diterapkan.", "success")
        end)

        SettingsTab:AddButton("Reset Default", 10723344432, function()
            ApplyPreset("Default"); presetDrop:SetValue("Default", false)
            if self.SettingsRefs.AccentBox then self.SettingsRefs.AccentBox.Text = "#6C3BFF" end
            if self.SettingsRefs.BackgroundBox then self.SettingsRefs.BackgroundBox.Text = "#08080E" end
            self:Notify("Tema", "Dikembalikan ke Default.", "success")
        end)
        
        SettingsTab:AddSectionDivider("Global Watermark")

SettingsTab:AddSlider("Ukuran Teks WM", 10723344432, 50, 100, 45, function(val)
    if self._GlobalWM and self._GlobalWM.Parent then
        for _, child in ipairs(self._GlobalWM:GetChildren()) do
            if child:IsA("TextLabel") then
                child.TextSize = val
                child.TextScaled = false
            end
        end
    end
end)

SettingsTab:AddSlider("Transparansi WM", 10723344432, 20, 47, 25, function(val)
    if self._GlobalWM and self._GlobalWM.Parent then
        for _, child in ipairs(self._GlobalWM:GetChildren()) do
            if child:IsA("TextLabel") then
                child.TextTransparency = val / 100
            end
        end
    end
end)

