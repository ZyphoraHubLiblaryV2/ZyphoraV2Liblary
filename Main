local Players = game:GetService("Players")

local Player = Players.LocalPlayer

local Gui = Instance.new("ScreenGui")
Gui.Name = "MaintenanceUI"
Gui.IgnoreGuiInset = true
Gui.ResetOnSpawn = false
Gui.Parent = Player:WaitForChild("PlayerGui")

local BG = Instance.new("Frame")
BG.Size = UDim2.fromScale(1,1)
BG.BackgroundColor3 = Color3.fromRGB(15,15,15)
BG.BackgroundTransparency = 0.15
BG.Parent = Gui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1,0,0,70)
Title.Position = UDim2.new(0,0,0.15,0)
Title.BackgroundTransparency = 1
Title.Text = "🛠️ MAINTENANCE 🛠️"
Title.Font = Enum.Font.GothamBold
Title.TextScaled = true
Title.TextColor3 = Color3.fromRGB(255, 200, 80)
Title.Parent = BG

local Desc = Instance.new("TextLabel")
Desc.Size = UDim2.new(0.7,0,0.2,0)
Desc.Position = UDim2.new(0.15,0,0.32,0)
Desc.BackgroundTransparency = 1
Desc.TextWrapped = true
Desc.TextScaled = true
Desc.Font = Enum.Font.Gotham
Desc.TextColor3 = Color3.new(1,1,1)
Desc.Text = "This script is currently under maintenance.\nPlease check back later."
Desc.Parent = BG

-- Tombol Close
local Close = Instance.new("TextButton")
Close.Size = UDim2.new(0,130,0,50)
Close.Position = UDim2.new(0.35,-65,0.72,0)
Close.BackgroundColor3 = Color3.fromRGB(60, 120, 220)
Close.Text = "Close"
Close.Font = Enum.Font.GothamBold
Close.TextColor3 = Color3.new(1,1,1)
Close.TextScaled = true
Close.Parent = BG

Instance.new("UICorner", Close).CornerRadius = UDim.new(0,10)

Close.MouseButton1Click:Connect(function()
    Gui:Destroy()
end)

-- Tombol Alasan (Reason)
local ReasonBtn = Instance.new("TextButton")
ReasonBtn.Size = UDim2.new(0,130,0,50)
ReasonBtn.Position = UDim2.new(0.65,-65,0.72,0)
ReasonBtn.BackgroundColor3 = Color3.fromRGB(220, 180, 60)
ReasonBtn.Text = "Reason"
ReasonBtn.Font = Enum.Font.GothamBold
ReasonBtn.TextColor3 = Color3.new(1,1,1)
ReasonBtn.TextScaled = true
ReasonBtn.Parent = BG

Instance.new("UICorner", ReasonBtn).CornerRadius = UDim.new(0,10)

-- Pop-up Alasan FULL SCREEN
local ReasonPopup = Instance.new("Frame")
ReasonPopup.Size = UDim2.fromScale(1,1)
ReasonPopup.Position = UDim2.fromScale(0,0)
ReasonPopup.BackgroundColor3 = Color3.fromRGB(20,20,20)
ReasonPopup.BackgroundTransparency = 0.05
ReasonPopup.Visible = false
ReasonPopup.Parent = Gui

local PopupTitle = Instance.new("TextLabel")
PopupTitle.Size = UDim2.new(1,0,0,100)
PopupTitle.Position = UDim2.new(0,0,0.05,0)
PopupTitle.BackgroundTransparency = 1
PopupTitle.Text = "Reason Maintenance"
PopupTitle.Font = Enum.Font.GothamBold
PopupTitle.TextScaled = true
PopupTitle.TextColor3 = Color3.fromRGB(255, 200, 80)
PopupTitle.Parent = ReasonPopup

local PopupDesc = Instance.new("TextLabel")
PopupDesc.Size = UDim2.new(0.8,0,0.6,0)
PopupDesc.Position = UDim2.new(0.1,0,0.2,0)
PopupDesc.BackgroundTransparency = 1
PopupDesc.TextWrapped = true
PopupDesc.TextScaled = true
PopupDesc.Font = Enum.Font.Gotham
PopupDesc.TextColor3 = Color3.new(1,1,1)
PopupDesc.Text = "This script is currently under maintenance\n\nScript Seller Troubleshooting\n\nThe script will be back up and running once the issue is resolved."
PopupDesc.Parent = ReasonPopup

local ClosePopup = Instance.new("TextButton")
ClosePopup.Size = UDim2.new(0,200,0,60)
ClosePopup.Position = UDim2.new(0.5,-100,0.85,0)
ClosePopup.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
ClosePopup.Text = "Back"
ClosePopup.Font = Enum.Font.GothamBold
ClosePopup.TextColor3 = Color3.new(1,1,1)
ClosePopup.TextScaled = true
ClosePopup.Parent = ReasonPopup

Instance.new("UICorner", ClosePopup).CornerRadius = UDim.new(0,12)

-- Fungsi toggle popup
ReasonBtn.MouseButton1Click:Connect(function()
    ReasonPopup.Visible = not ReasonPopup.Visible
end)

ClosePopup.MouseButton1Click:Connect(function()
    ReasonPopup.Visible = false
end)

-- Klik di luar popup untuk menutup
BG.MouseButton1Click:Connect(function()
    if ReasonPopup.Visible then
        ReasonPopup.Visible = false
    end
end)
