-- FPS Counter
task.spawn(function()
    local lastTime = tick()
    local frameCount = 0
    local fps = 0
    
    while WM and WM.Parent do
        frameCount = frameCount + 1
        local currentTime = tick()
        local deltaTime = currentTime - lastTime
        
        if deltaTime >= 1 then
            fps = frameCount
            frameCount = 0
            lastTime = currentTime
            
            -- Update teks FPS
            FPSText.Text = string.format(
                "Zyphora Hub  <font color='#6C3BFF'>|</font>  <font color='#9B8FBF'>by Rexz</font>  <font color='#5A5070'>| </font><font color='#6C3BFF'>FPS: %d</font>  ",
                fps
            )
        end
        
        task.wait()
    end
end)

