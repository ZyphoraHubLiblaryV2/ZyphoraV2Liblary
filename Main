-- Resize Handle (buat dulu sebelum connect event)
local ResizeHandle = New("TextButton", {
    Size = UDim2.new(0,28,0,28),
    Position = UDim2.new(1,-28,1,-28),
    BackgroundColor3 = T.Border,
    Text = "в ҝ",
    TextColor3 = T.TextMuted,
    TextSize = 14,
    ZIndex = 50,
    Active = true,
    BorderSizePixel = 0,
    Parent = MainFrame,
})
Corner(ResizeHandle, 4)

local resizing = false
local resizeStart = nil
local resizeStartSize = nil

ResizeHandle.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true
        resizeStart = inp.Position
        resizeStartSize = MainFrame.AbsoluteSize
        MainFrame.Active = false
    end
end)

UserInputService.InputChanged:Connect(function(inp)
    if not resizing then return end
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = inp.Position - resizeStart
        local newW = math.clamp(resizeStartSize.X + delta.X, 400, 800)
        local newH = math.clamp(resizeStartSize.Y + delta.Y, 300, 600)
        MainFrame.Size = UDim2.new(0, newW, 0, newH)
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
        MainFrame.Active = true
    end
end)

