local clickCount = 0
local lastClickTime = 0
local eggUnlocked = false

-- Bikin MainIcon clickable (ImageLabel default nggak ada event klik, ganti pakai invisible button overlay)
local IconClickArea = New("TextButton", {
    Name = "IconClickArea",
    Size = UDim2.new(0, 24, 0, 24),
    Position = UDim2.new(0, 20, 0.5, -12),
    BackgroundTransparency = 1,
    Text = "",
    ZIndex = 5,
    Parent = TopBar,
})

IconClickArea.MouseButton1Click:Connect(function()
    local now = tick()
    if now - lastClickTime > 1.2 then
        clickCount = 0 -- reset kalau kelamaan jeda
    end
    lastClickTime = now
    clickCount = clickCount + 1

    if clickCount >= 7 and not eggUnlocked then
        eggUnlocked = true
        clickCount = 0

        -- Efek confetti warna-warni dari title
        self:Notify("рҹҘҡ Easter Egg!", "Kamu nemu rahasia tersembunyi Zyphora Hub!", "success", 5)

        -- Title berubah sementara jadi pesan rahasia
        local originalText = TitleGlow.Text
        TitleGlow.Text = "рҹ•ҠпёҸ ZYPHORA WAS HERE рҹ•ҠпёҸ"

        -- Rainbow burst sebentar di MainIcon
        task.spawn(function()
            for i = 1, 40 do
                local hue = (i * 0.05) % 1
                MainIcon.ImageColor3 = Color3.fromHSV(hue, 0.9, 1)
                task.wait(0.03)
            end
            MainIcon.ImageColor3 = T.AccentBright
        end)

        -- Window goyang-goyang kecil
        local originalPos = MainFrame.Position
        task.spawn(function()
            for i = 1, 6 do
                local offset = (i % 2 == 0) and 4 or -4
                TweenService:Create(MainFrame, TI(0.05), {
                    Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + offset, originalPos.Y.Scale, originalPos.Y.Offset)
                }):Play()
                task.wait(0.05)
            end
            TweenService:Create(MainFrame, TI(0.1), { Position = originalPos }):Play()
        end)

        -- Balikin title setelah beberapa detik
        task.delay(4, function()
            if TitleGlow then TitleGlow.Text = originalText end
        end)

        -- Reset supaya bisa di-trigger lagi setelah 30 detik (biar bisa dipamerin ke teman)
        task.delay(30, function() eggUnlocked = false end)
    end
end)

