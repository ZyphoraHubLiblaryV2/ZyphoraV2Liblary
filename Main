-- ============================================
-- SCENE 1: INITIAL POP-IN
-- ============================================
local function playScene1()
    playSound(CONFIG.Sounds.Open)

    local boxTween = TweenService:Create(Box, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(230, 110),
    })
    boxTween:Play()
    boxTween.Completed:Wait()

    task.wait(0.1)

    -- Logo pop-in (ring + isi logo bareng)
    local logoTween = TweenService:Create(LogoRing, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(42, 42),
    })
    logoTween:Play()

    if usingImage then
        TweenService:Create(LogoImg, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            ImageTransparency = 0,
        }):Play()
    else
        TweenService:Create(LogoTxt, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            TextTransparency = 0,
        }):Play()
    end

    logoTween.Completed:Wait()
    task.wait(0.1)

    Title.Position = UDim2.new(0, 12, 0, 68)
    Title.Text = "Script By Rexz"

    TweenService:Create(Title, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 0,
    }):Play()

    Sub.Position = UDim2.new(0, 12, 0, 88)
    Sub.Text = "Zyphora Hub V2"

    TweenService:Create(Sub, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 0,
    }):Play()

    TweenService:Create(BoxStroke, TweenInfo.new(1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        Color = Color3.fromRGB(60, 140, 255),
    }):Play()

    TweenService:Create(LogoStroke, TweenInfo.new(0.6, Enum.EasingStyle.Sine), {
        Color = Color3.fromRGB(100, 160, 255),
    }):Play()

    task.wait(1.6)
end

-- ============================================
-- SCENE 2: EXPAND & LOAD
-- ============================================
local function playScene2()
    playSound(CONFIG.Sounds.Whoosh)

    Title.Text = "ZYPHORA HUB V2"
    Sub.Text = "Mohon tunggu sebentar..."

    local expandTween = TweenService:Create(Box, TweenInfo.new(0.65, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(460, 210),
    })
    expandTween:Play()

    TweenService:Create(BoxStroke, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Color = Color3.fromRGB(100, 55, 240),
    }):Play()

    TweenService:Create(LogoStroke, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Color = Color3.fromRGB(150, 110, 250),
    }):Play()

    expandTween.Completed:Wait()
    task.wait(0.2)

    Title.Position = UDim2.new(0, 12, 0, 64)
    Sub.Position = UDim2.new(0, 12, 0, 90)
    LogoRing.Position = UDim2.new(0.5, 0, 0, 18)

    ProgBg.Visible = true
    StatusTxt.Visible = true

    TweenService:Create(StatusTxt, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 0,
    }):Play()

    TweenService:Create(PctTxt, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 0,
    }):Play()

    -- ============================================
    -- LOADING STEPS
    -- ============================================
    local steps = {
        { text = "Memuat library script...",     pct = 0.25, delay = 0.45 },
        { text = "Menyiapkan tema UI...",        pct = 0.50, delay = 0.40 },
        { text = "Menginisialisasi komponen...", pct = 0.78, delay = 0.40 },
        { text = "Hampir selesai...",            pct = 0.92, delay = 0.35 },
        { text = "Selesai!",                     pct = 1.00, delay = 0.30 },
    }

    for idx, step in ipairs(steps) do
        StatusTxt.Text = step.text
        playSound(idx == #steps and CONFIG.Sounds.Complete or CONFIG.Sounds.Tick)

        local progTween = TweenService:Create(Prog, TweenInfo.new(step.delay, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(step.pct, 0, 1, 0),
        })
        progTween:Play()

        -- animasi angka persen biar gak loncat kasar
        task.spawn(function()
            local startPct = tonumber(PctTxt.Text:match("%d+")) or 0
            local endPct = math.floor(step.pct * 100)
            local steps2 = math.max(1, endPct - startPct)
            for p = startPct, endPct, math.max(1, math.floor(steps2 / 10)) do
                if PctTxt and PctTxt.Parent then
                    PctTxt.Text = math.min(p, endPct) .. "%"
                end
                task.wait(step.delay / 10)
            end
            if PctTxt and PctTxt.Parent then
                PctTxt.Text = endPct .. "%"
            end
        end)

        progTween.Completed:Wait()
    end

    task.wait(0.3)
end

-- ============================================
-- SCENE 3: FADE OUT
-- ============================================
local function playScene3()
    local bgFade = TweenService:Create(Bg, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1,
    })
    bgFade:Play()

    local cardFade = TweenService:Create(Box, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1,
        Size = UDim2.fromOffset(460, 200),
    })
    cardFade:Play()

    for _, child in ipairs(Box:GetDescendants()) do
        pcall(function()
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                TweenService:Create(child, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    TextTransparency = 1,
                }):Play()
            elseif child:IsA("Frame") or child:IsA("ImageLabel") then
                TweenService:Create(child, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    BackgroundTransparency = 1,
                    ImageTransparency = 1,
                }):Play()
            elseif child:IsA("UIStroke") then
                TweenService:Create(child, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Transparency = 1,
                }):Play()
            end
        end)
    end

    for _, dot in ipairs(particles) do
        pcall(function()
            TweenService:Create(dot, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                BackgroundTransparency = 1,
            }):Play()
        end)
    end

    task.wait(0.5)

    pcall(function()
        Gui:Destroy()
    end)
end

-- ============================================
-- EXECUTE ALL SCENES
-- ============================================
task.spawn(function()
    pcall(function()
        playScene1()
        playScene2()
        playScene3()
    end)
end)

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
