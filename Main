local CONFIG = {
    LogoImageId = "rbxassetid://82539886579242", -- <-- GANTI dengan asset id logo kamu, contoh: "rbxassetid://123456789"
    SoundEnabled = true,
    SoundVolume = 1,
    Sounds = {
        Open = "rbxassetid://9120683780",     -- pop-in card
        Whoosh = "rbxassetid://9120683313",   -- expand
