-- ============================================
-- DARK BACKGROUND
-- ============================================
local Bg = Instance.new("Frame")
Bg.Size = UDim2.fromScale(1, 1)
Bg.BackgroundColor3 = Color3.fromRGB(6, 6, 12)
Bg.BorderSizePixel = 0
Bg.ZIndex = 1
Bg.Parent = Gui

local BgGrad = Instance.new("UIGradient")
BgGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(8, 6, 18)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(14, 10, 28)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(6, 6, 16)),
})
BgGrad.Rotation = 160
BgGrad.Parent = Bg

-- ============================================
-- DECORATIVE PARTICLES
-- ============================================
local particles = {}
for i = 1, 18 do
    local Dot = Instance.new("Frame")
    Dot.Size = UDim2.fromOffset(math.random(2, 5), math.random(2, 5))
    Dot.Position = UDim2.fromScale(math.random(0, 100) / 100, math.random(0, 100) / 100)
    Dot.BackgroundColor3 = Color3.fromRGB(100, 65, 230)
    Dot.BackgroundTransparency = math.random(50, 85) / 100
    Dot.BorderSizePixel = 0
    Dot.ZIndex = 2
    Dot.Parent = Bg

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(1, 0)
    Corner.Parent = Dot

    particles[i] = Dot
end

for i, dot in ipairs(particles) do
    task.spawn(function()
        local startDelay = math.random(0, 20) / 10
        task.wait(startDelay)

        while dot and dot.Parent do
            local tweenInfo = TweenInfo.new(
                math.random(15, 30) / 10,
                Enum.EasingStyle.Sine,
                Enum.EasingDirection.InOut,
                -1,
                true
            )

            pcall(function()
                TweenService:Create(dot, tweenInfo, {
                    BackgroundTransparency = math.random(70, 95) / 100,
                    Position = UDim2.fromScale(
                        math.random(10, 90) / 100,
                        math.random(10, 90) / 100
                    ),
                }):Play()
            end)

            task.wait(math.random(20, 40) / 10)
        end
    end)
end

