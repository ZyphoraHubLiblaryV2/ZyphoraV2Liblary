     -- minimize
local function MinimizeWindow()
    if self.Hidden then return end
    self.Minimized = not self.Minimized
    local target = self.Minimized and UDim2.new(0,520,0,40) or UDim2.new(0,520,0,340)
    TweenService:Create(MainFrame, TI(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = target }):Play()
    local show = not self.Minimized
    task.delay(self.Minimized and 0 or 0.15, function()
        if self._uiRefs.SidebarBg then self._uiRefs.SidebarBg.Visible = show end
        if self._uiRefs.SidebarDiv then self._uiRefs.SidebarDiv.Visible = show end
        if self.Sidebar then self.Sidebar.Visible = show end
        if self._uiRefs.SearchBar then self._uiRefs.SearchBar.Visible = show end
        if self.ContentHolder then self.ContentHolder.Visible = show end
        -- FIX: hide semua pinned tab button & scroll
        for _, tab in ipairs(self.Tabs) do
            if tab.Button and tab.Button.Parent == MainFrame then
                tab.Button.Visible = show
            end
            if tab.ScrollBox then tab.ScrollBox.Visible = show and tab == self.CurrentTab end
        end
    end)
end

    local function ToggleHideWindow()
        self.Hidden = not self.Hidden
        if self.Hidden then
            local tw = TweenService:Create(MainFrame, TI(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                BackgroundTransparency = 1, Size = UDim2.new(0,520,0,0)
            })
            tw:Play()
            tw.Completed:Once(function() MainFrame.Visible = false end)
        else
            MainFrame.Visible = true
            MainFrame.BackgroundTransparency = 1
            MainFrame.Size = UDim2.new(0,520,0,0)
            local target = self.Minimized and UDim2.new(0,520,0,40) or UDim2.new(0,520,0,340)
            TSpring(MainFrame, { BackgroundTransparency = 0, Size = target })
            if not self.Minimized then
                task.delay(0.1, function()
                    if self._uiRefs.SidebarBg then self._uiRefs.SidebarBg.Visible = true end
                    if self._uiRefs.SidebarDiv then self._uiRefs.SidebarDiv.Visible = true end
                    if self.Sidebar then self.Sidebar.Visible = true end
                    if self._uiRefs.SearchBar then self._uiRefs.SearchBar.Visible = true end
                    if self.ContentHolder then self.ContentHolder.Visible = true end
                    for _, tab in ipairs(self.Tabs) do
    if tab.Button and tab.Button.Parent == MainFrame then
        tab.Button.Visible = true
    end
end
                end)
            end
        end
    end
    ToggleBtn.MouseButton1Click:Connect(ToggleHideWindow)
    
