-- Toggle
function TabClass:AddToggle(text, iconId, defaultState, callback)
    local T    = self.Library.Theme
    local state= defaultState or false
    local act  = callback or function() end

    local El = New("TextButton", {
        Name = text .. "_Toggle",
        Size = UDim2.new(1,-4,0,38),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,12,0.5,-7),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 32 or 12
    local TText = New("TextLabel", {
        Name = "TText",
        Size = UDim2.new(1, -xOff-52, 1, 0),
        Position = UDim2.new(0, xOff, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    -- Toggle pill
    local Pill = New("Frame", {
        Name = "Pill",
        Size = UDim2.new(0,36,0,20),
        Position = UDim2.new(1,-46,0.5,-10),
        BackgroundColor3 = T.ToggleOff,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Pill, 50)
    Stroke(Pill, T.Border, 1)

    local Knob = New("Frame", {
        Name = "Knob",
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new(0,3,0.5,-7),
        BackgroundColor3 = T.TextMuted,
        BorderSizePixel = 0,
        Parent = Pill,
    })
    Corner(Knob, 50)

    local function UpdateVisual(animate)
        local targetBg    = state and T.ToggleOn or T.ToggleOff
        local targetKnob  = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
        local knobColor   = state and Color3.fromRGB(255,255,255) or T.TextMuted
        local strokeColor = state and T.Accent or T.Border
        if animate then
            TFast(Pill, { BackgroundColor3 = targetBg })
            TSpring(Knob, { Position = targetKnob })
            TFast(Knob, { BackgroundColor3 = knobColor })
            TFast(Stroke(Pill, strokeColor, 1), {})  -- re-apply stroke color
            -- Pulse the glow on activate
            if state then
                Tween(El, TI(0.12), { BackgroundColor3 = T.SurfaceTop })
                task.wait(0.12)
                TFast(El, { BackgroundColor3 = T.Surface })
            end
        else
            Pill.BackgroundColor3 = targetBg
            Knob.Position = targetKnob
            Knob.BackgroundColor3 = knobColor
        end
    end

    UpdateVisual(false)

    El.MouseEnter:Connect(function()
        TFast(El, { BackgroundColor3 = T.SurfaceHigh })
        TFast(ElStroke, { Color = T.BorderLight })
    end)
    El.MouseLeave:Connect(function()
        TFast(El, { BackgroundColor3 = T.Surface })
        TFast(ElStroke, { Color = T.Border })
    end)
    El.MouseButton1Click:Connect(function()
        state = not state
        self.Library.ToggleStates[text] = state
        UpdateVisual(true)
        pcall(act, state)
    end)

    self.Library.ToggleStates[text] = state
    self.Library.ToggleRegistry[text] = {
        SetState = function(newState, fire)
            state = newState and true or false
            self.Library.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(act, state) end
        end
    }

    table.insert(self.Library.ControlRegistry, { Kind = "Toggle", Root = El, RootStroke = ElStroke, Title = TText, Icon = Icon, TText = TText })
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return state end,
        SetValue = function(v, fire)
            state = v and true or false
            self.Library.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(act, state) end
        end
    }
end

-- Input
function TabClass:AddInput(text, iconId, placeholder, callback)
    local T   = self.Library.Theme
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Input",
        Size = UDim2.new(1,-4,0,44),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,9),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = El,
        })
    end

    local xOff = iconId and 30 or 12
    local Title = New("TextLabel", {
        Size = UDim2.new(1,-xOff-12,0,16),
        Position = UDim2.new(0,xOff,0,6),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local Box = New("TextBox", {
        Name = "InputBox",
        Size = UDim2.new(1,-xOff-12,0,16),
        Position = UDim2.new(0,xOff,0,24),
        BackgroundTransparency = 1,
        Text = "",
        PlaceholderText = tostring(placeholder or ""),
        PlaceholderColor3 = T.TextMuted,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        Parent = El,
    })

    -- Underline for input box
    local Underline = New("Frame", {
        Size = UDim2.new(1,-xOff-12,0,1),
        Position = UDim2.new(0,xOff,1,-5),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = El,
    })

    Box.Focused:Connect(function()
        TFast(ElStroke, { Color = T.Accent })
        TFast(Underline, { BackgroundColor3 = T.Accent })
    end)
    Box.FocusLost:Connect(function(enter)
        TFast(ElStroke, { Color = T.Border })
        TFast(Underline, { BackgroundColor3 = T.Border })
        pcall(act, Box.Text, enter)
    end)

    table.insert(self.Library.ControlRegistry, { Kind = "Input", Root = El, RootStroke = ElStroke, Title = Title, Icon = Icon, Box = Box })
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        Box = Box,
        GetValue = function() return Box.Text end,
        SetValue = function(v) Box.Text = tostring(v or "") end,
    }
end

-- Slider
function TabClass:AddSlider(text, iconId, min, max, default, callback)
    local T   = self.Library.Theme
    local val = default or min
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Slider",
        Size = UDim2.new(1,-4,0,54),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)

    local ElStroke = Stroke(El, T.Border, 1)

    local Label = New("TextLabel", {
        Size = UDim2.new(1,-60,0,18),
        Position = UDim2.new(0,12,0,7),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local ValLbl = New("TextLabel", {
        Size = UDim2.new(0,50,0,18),
        Position = UDim2.new(1,-58,0,7),
        BackgroundTransparency = 1,
        Text = tostring(val),
        TextColor3 = T.AccentBright,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = El,
    })

    local Track = New("Frame", {
        Name = "Track",
        Size = UDim2.new(1,-24,0,6),
        Position = UDim2.new(0,12,0,34),
        BackgroundColor3 = T.SurfaceHigh,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Track, 3)

    local Fill = New("Frame", {
        Size = UDim2.new((val-min)/(max-min),0,1,0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = Track,
    })
    Corner(Fill, 3)

    local Thumb = New("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new((val-min)/(max-min),0,0.5,-7),
        AnchorPoint = Vector2.new(0.5,0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0,
        Parent = Track,
    })

    Corner(Thumb, 50)
    Stroke(Thumb, T.Accent, 2)

    local HitBox = New("TextButton", {
        Size = UDim2.new(1,0,1,24),
        Position = UDim2.new(0,0,0,-12),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 5,
        Parent = Track,
    })

    local dragging = false

    local function SetSlider(v)
        val = math.clamp(v, min, max)

        local pct = (val-min)/(max-min)

        Fill.Size = UDim2.new(pct,0,1,0)
        Thumb.Position = UDim2.new(pct,0,0.5,-7)

        ValLbl.Text = tostring(val)

        if self.Library.SliderRegistry[text] then
    self.Library.SliderRegistry[text].Value = val
end

        pcall(act, val)
    end

    local function Update(x)
        local abs = Track.AbsolutePosition.X
        local sz  = Track.AbsoluteSize.X

        if sz <= 0 then
            return
        end

        local pct = math.clamp((x-abs)/sz, 0, 1)

        local v = math.floor(min + (max-min)*pct + 0.5)

        SetSlider(v)
    end

    HitBox.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then

            dragging = true
            Update(inp.Position.X)
        end
    end)

    HitBox.InputChanged:Connect(function(inp)
        if dragging and (
            inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch
        ) then
            Update(inp.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then
            return
        end

        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            Update(inp.Position.X)
        end
    end)

    El.MouseEnter:Connect(function()
        TFast(ElStroke, {
            Color = T.BorderLight
        })
    end)

    El.MouseLeave:Connect(function()
        TFast(ElStroke, {
            Color = T.Border
        })
    end)

    -- SAVE REGISTRY
    self.Library.SliderRegistry[text] = {
        Value = val,
        SetValue = SetSlider
    }

    table.insert(self.Library.ControlRegistry, {
        Kind = "Slider",
        Root = El,
        RootStroke = ElStroke,
        Title = Label,
        Track = Track
    })

    table.insert(self.Elements, {
        Name = text,
        Instance = El
    })

    return {
        GetValue = function()
            return val
        end,

        SetValue = SetSlider
    }
end

-- Textbox alias
function TabClass:AddTextbox(text, iconId, placeholder, callback)
    return self:AddInput(text, iconId, placeholder, callback)
end

-- Dropdown
function TabClass:AddDropdown(text, iconId, options, defaultValue, callback)
    local T      = self.Library.Theme
    local act    = callback or function() end
    local open   = false
    local list   = options or {}
    local sel    = defaultValue or (list[1] or "None")

    local Root = New("TextButton", {
        Name = text .. "_Dropdown",
        Size = UDim2.new(1,-4,0,40),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(Root, 8)
    local RootStroke = Stroke(Root, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,12),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Root,
        })
    end

    local xOff = iconId and 30 or 12
    local Lbl = New("TextLabel", {
        Size = UDim2.new(1,-xOff-30,0,16),
        Position = UDim2.new(0,xOff,0,4),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ValLbl = New("TextLabel", {
        Name = "ValLbl",
        Size = UDim2.new(1,-xOff-30,0,14),
        Position = UDim2.new(0,xOff,0,21),
        BackgroundTransparency = 1,
        Text = tostring(sel),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ArrowLbl = New("TextLabel", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(1,-26,0,10),
        BackgroundTransparency = 1,
        Text = "в–ҫ",
        TextColor3 = T.TextMuted,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Root,
    })

    -- Separator line in dropdown
    local Sep = New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,39),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Root,
    })

    -- Options container
    local OptHolder = New("Frame", {
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,40),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Root,
    })

    local OptScroll = New("ScrollingFrame", {
        Size = UDim2.new(1,-8,1,0),
        Position = UDim2.new(0,4,0,0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Parent = OptHolder,
    })

    local OptLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,3),
        Parent = OptScroll,
    })

    local function SetValue(v, fire)
        sel = tostring(v); ValLbl.Text = sel
        if fire then pcall(act, sel) end
    end

    local function Rebuild()
        for _, c in ipairs(OptScroll:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for i, opt in ipairs(list) do
            local isSel = tostring(opt) == sel
            local Btn = New("TextButton", {
                Name = "Opt" .. i,
                Size = UDim2.new(1,0,0,26),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                Parent = OptScroll,
            })
            Corner(Btn, 5)
            if isSel then Stroke(Btn, T.Accent, 1) end

            New("TextLabel", {
                Size = UDim2.new(1,-14,1,0),
                Position = UDim2.new(0,8,0,0),
                BackgroundTransparency = 1,
                Text = tostring(opt),
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Btn,
            })

            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(0,14,1,0),
                    Position = UDim2.new(1,-16,0,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = T.AccentBright,
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = Btn,
                })
            end

            Btn.MouseEnter:Connect(function() TFast(Btn, { BackgroundColor3 = T.SurfaceTop }) end)
            Btn.MouseLeave:Connect(function() TFast(Btn, { BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh }) end)
            Btn.MouseButton1Click:Connect(function()
                SetValue(opt, true)
                open = false
                TFast(Root, { Size = UDim2.new(1,-4,0,40) })
                TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
                TFast(Sep, { BackgroundTransparency = 0 })
                ArrowLbl.Text = "в–ҫ"
                Rebuild()
            end)
        end
        local h = math.min(OptLayout.AbsoluteContentSize.Y + 4, 115)
        OptScroll.CanvasSize = UDim2.new(0,0,0, OptLayout.AbsoluteContentSize.Y + 4)
        return h
    end

    Root.MouseButton1Click:Connect(function()
        open = not open
        if open then
            local h = Rebuild()
            TSpring(OptHolder, { Size = UDim2.new(1,0,0,h) })
            TSpring(Root, { Size = UDim2.new(1,-4,0,40+h+6) })
            TFast(RootStroke, { Color = T.Accent })
            ArrowLbl.Text = "в–ҙ"
        else
            TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
            TFast(Root, { Size = UDim2.new(1,-4,0,40) })
            TFast(RootStroke, { Color = T.Border })
            ArrowLbl.Text = "в–ҫ"
        end
    end)

    SetValue(sel, false)

    table.insert(self.Library.ControlRegistry, { Kind = "Dropdown", Root = Root, RootStroke = RootStroke, Title = Lbl, Icon = Icon, ValLabel = ValLbl })
    table.insert(self.Elements, { Name = text, Instance = Root })

    local api = {}
    function api:GetValue() return sel end
    function api:SetValue(v, fire) SetValue(v, fire) end
    function api:SetOptions(newOpts, newDef, fireDef)
        list = newOpts or {}
        if newDef ~= nil then SetValue(newDef, fireDef) end
        if open then Rebuild() end
    end
    return api
end

-- Multi Dropdown
function TabClass:AddMultiDropdown(text, iconId, options, defaultValues, callback)
    local T      = self.Library.Theme
    local act    = callback or function() end
    local open   = false
    local list   = options or {}
    local chosen = {}

    -- Set default values
    if defaultValues then
        for _, v in ipairs(defaultValues) do
            chosen[tostring(v)] = true
        end
    end

    local function GetSelected()
        local result = {}
        for _, opt in ipairs(list) do
            if chosen[tostring(opt)] then
                table.insert(result, tostring(opt))
            end
        end
        return result
    end

    local function GetDisplayText()
        local sel = GetSelected()
        if #sel == 0 then return "Tidak ada dipilih" end
        if #sel == 1 then return sel[1] end
        return sel[1] .. " +" .. (#sel - 1) .. " lainnya"
    end

    local Root = New("TextButton", {
        Name = text .. "_MultiDropdown",
        Size = UDim2.new(1,-4,0,40),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Text = "",
        AutoButtonColor = false,
        Parent = self.ScrollBox,
    })
    Corner(Root, 8)
    local RootStroke = Stroke(Root, T.Border, 1)

    local Icon = nil
    if iconId then
        Icon = New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0,12),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Root,
        })
    end

    local xOff = iconId and 30 or 12

    local Lbl = New("TextLabel", {
        Size = UDim2.new(1,-xOff-30,0,16),
        Position = UDim2.new(0,xOff,0,4),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ValLbl = New("TextLabel", {
        Name = "ValLbl",
        Size = UDim2.new(1,-xOff-30,0,14),
        Position = UDim2.new(0,xOff,0,21),
        BackgroundTransparency = 1,
        Text = GetDisplayText(),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Root,
    })

    local ArrowLbl = New("TextLabel", {
        Size = UDim2.new(0,20,0,20),
        Position = UDim2.new(1,-26,0,10),
        BackgroundTransparency = 1,
        Text = "в–ҫ",
        TextColor3 = T.TextMuted,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Root,
    })

    -- Counter badge
    local CountBadge = New("Frame", {
        Size = UDim2.new(0,18,0,18),
        Position = UDim2.new(1,-48,0,11),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Visible = false,
        Parent = Root,
    })
    Corner(CountBadge, 50)
    local CountLbl = New("TextLabel", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        Text = "0",
        TextColor3 = Color3.fromRGB(255,255,255),
        TextSize = 9,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = CountBadge,
    })

    local Sep = New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,39),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Root,
    })

    local OptHolder = New("Frame", {
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,40),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Root,
    })

    local OptScroll = New("ScrollingFrame", {
        Size = UDim2.new(1,-8,1,0),
        Position = UDim2.new(0,4,0,0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Parent = OptHolder,
    })

    local OptLayout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,3),
        Parent = OptScroll,
    })

    -- Select All / Clear Row
    local CtrlRow = New("Frame", {
        Size = UDim2.new(1,-8,0,22),
        BackgroundTransparency = 1,
        Parent = OptScroll,
    })
    New("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        Padding = UDim.new(0,4),
        Parent = CtrlRow,
    })

    local function UpdateBadge()
        local sel = GetSelected()
        local count = #sel
        if count > 0 then
            CountBadge.Visible = true
            CountLbl.Text = tostring(count)
        else
            CountBadge.Visible = false
        end
        ValLbl.Text = GetDisplayText()
    end

    local function Rebuild()
        for _, c in ipairs(OptScroll:GetChildren()) do
            if c:IsA("TextButton") or (c:IsA("Frame") and c.Name ~= "CtrlRow") then
                c:Destroy()
            end
        end

        -- Select All button
        local SelAll = New("TextButton", {
            Size = UDim2.new(0.5,-2,1,0),
            BackgroundColor3 = T.SurfaceHigh,
            Text = "Pilih Semua",
            TextColor3 = T.AccentBright,
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = CtrlRow,
        })
        Corner(SelAll, 5)
        SelAll.MouseButton1Click:Connect(function()
            for _, opt in ipairs(list) do chosen[tostring(opt)] = true end
            UpdateBadge()
            Rebuild()
            pcall(act, GetSelected())
        end)

        -- Clear button
        local ClearBtn = New("TextButton", {
            Size = UDim2.new(0.5,-2,1,0),
            BackgroundColor3 = T.SurfaceHigh,
            Text = "Hapus Semua",
            TextColor3 = T.Error,
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = CtrlRow,
        })
        Corner(ClearBtn, 5)
        ClearBtn.MouseButton1Click:Connect(function()
            chosen = {}
            UpdateBadge()
            Rebuild()
            pcall(act, GetSelected())
        end)

        -- Divider
        New("Frame", {
            Size = UDim2.new(1,0,0,1),
            BackgroundColor3 = T.Border,
            BorderSizePixel = 0,
            Parent = OptScroll,
        })

        for i, opt in ipairs(list) do
            local key    = tostring(opt)
            local isSel  = chosen[key] == true

            local Row = New("TextButton", {
                Name = "Opt_" .. i,
                Size = UDim2.new(1,0,0,28),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Parent = OptScroll,
            })
            Corner(Row, 5)
            local RowStroke = Stroke(Row, isSel and T.Accent or T.Border, 1)

            -- Checkbox
            local CheckBox = New("Frame", {
                Size = UDim2.new(0,14,0,14),
                Position = UDim2.new(0,8,0.5,-7),
                BackgroundColor3 = isSel and T.Accent or T.SurfaceHigh,
                BorderSizePixel = 0,
                Parent = Row,
            })
            Corner(CheckBox, 4)
            Stroke(CheckBox, isSel and T.Accent or T.Border, 1)

            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(1,0,1,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = Color3.fromRGB(255,255,255),
                    TextSize = 9,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = CheckBox,
                })
            end

            New("TextLabel", {
                Size = UDim2.new(1,-36,1,0),
                Position = UDim2.new(0,28,0,0),
                BackgroundTransparency = 1,
                Text = key,
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Row,
            })

            Row.MouseEnter:Connect(function()
                if not chosen[key] then
                    TFast(Row, { BackgroundColor3 = T.SurfaceTop })
                    TFast(RowStroke, { Color = T.BorderLight })
                end
            end)
            Row.MouseLeave:Connect(function()
                if not chosen[key] then
                    TFast(Row, { BackgroundColor3 = T.SurfaceHigh })
                    TFast(RowStroke, { Color = T.Border })
                end
            end)
            Row.MouseButton1Click:Connect(function()
                chosen[key] = not chosen[key] or nil
                UpdateBadge()
                Rebuild()
                pcall(act, GetSelected())
            end)
        end

        local h = math.min(OptLayout.AbsoluteContentSize.Y + 4, 140)
        OptScroll.CanvasSize = UDim2.new(0,0,0, OptLayout.AbsoluteContentSize.Y + 4)
        return h
    end

    Root.MouseButton1Click:Connect(function()
        open = not open
        if open then
            local h = Rebuild()
            TSpring(OptHolder, { Size = UDim2.new(1,0,0,h) })
            TSpring(Root, { Size = UDim2.new(1,-4,0,40+h+6) })
            TFast(RootStroke, { Color = T.Accent })
            ArrowLbl.Text = "в–ҙ"
        else
            TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
            TFast(Root, { Size = UDim2.new(1,-4,0,40) })
            TFast(RootStroke, { Color = T.Border })
            ArrowLbl.Text = "в–ҫ"
        end
    end)

    UpdateBadge()

    table.insert(self.Library.ControlRegistry, { Kind = "Dropdown", Root = Root, RootStroke = RootStroke, Title = Lbl, Icon = Icon, ValLabel = ValLbl })
    table.insert(self.Elements, { Name = text, Instance = Root })

    local api = {}
    function api:GetValue() return GetSelected() end
    function api:SetValue(tbl, fire)
        chosen = {}
        if type(tbl) == "table" then
            for _, v in ipairs(tbl) do chosen[tostring(v)] = true end
        end
        UpdateBadge()
        if open then Rebuild() end
        if fire then pcall(act, GetSelected()) end
    end
    function api:SetOptions(newOpts, fire)
        list = newOpts or {}
        chosen = {}
        UpdateBadge()
        if open then Rebuild() end
        if fire then pcall(act, GetSelected()) end
    end
    return api
end

-- List
function TabClass:AddList(text, iconId, items, callback)
    local T   = self.Library.Theme
    local act = callback or function() end
    local selected = nil

    local Wrap = New("Frame", {
        Name = text .. "_List",
        Size = UDim2.new(1,-4,0,0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = false,
        Parent = self.ScrollBox,
    })
    Corner(Wrap, 8)
    local WrapStroke = Stroke(Wrap, T.Border, 1)

    -- Header
    local Header = New("Frame", {
        Name = "Header",
        Size = UDim2.new(1,0,0,32),
        BackgroundTransparency = 1,
        Parent = Wrap,
    })

    if iconId then
        New("ImageLabel", {
            Size = UDim2.new(0,13,0,13),
            Position = UDim2.new(0,11,0.5,-6),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = Header,
        })
    end

    local xOff = iconId and 30 or 12
    New("TextLabel", {
        Size = UDim2.new(1,-xOff-12,1,0),
        Position = UDim2.new(0,xOff,0,0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Header,
    })

    -- Divider
    New("Frame", {
        Size = UDim2.new(1,-24,0,1),
        Position = UDim2.new(0,12,0,31),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Wrap,
    })

    -- Items Container
    local ItemsHolder = New("Frame", {
        Name = "ItemsHolder",
        Size = UDim2.new(1,0,0,0),
        Position = UDim2.new(0,0,0,36),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = Wrap,
    })
    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,2),
        Parent = ItemsHolder,
    })
    New("UIPadding", {
        PaddingLeft  = UDim.new(0,6),
        PaddingRight = UDim.new(0,6),
        PaddingBottom= UDim.new(0,6),
        Parent = ItemsHolder,
    })

    local itemRefs = {}

    local function BuildItems()
        for _, c in ipairs(ItemsHolder:GetChildren()) do
            if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
        end
        itemRefs = {}

        for i, item in ipairs(items or {}) do
            local isSel = tostring(item) == tostring(selected)

            local Row = New("TextButton", {
                Name = "Item_" .. i,
                Size = UDim2.new(1,0,0,28),
                BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                Text = "",
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Parent = ItemsHolder,
            })
            Corner(Row, 6)
            local RowStroke = isSel and Stroke(Row, T.Accent, 1) or Stroke(Row, T.Border, 1)

            -- Left accent dot
            local Dot = New("Frame", {
                Size = UDim2.new(0,4,0,4),
                Position = UDim2.new(0,8,0.5,-2),
                BackgroundColor3 = isSel and T.Accent or T.TextMuted,
                BorderSizePixel = 0,
                Parent = Row,
            })
            Corner(Dot, 50)

            New("TextLabel", {
                Size = UDim2.new(1,-42,1,0),
                Position = UDim2.new(0,20,0,0),
                BackgroundTransparency = 1,
                Text = tostring(item),
                TextColor3 = isSel and T.AccentBright or T.Text,
                TextSize = 11,
                Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Row,
            })

            -- Checkmark kalau selected
            if isSel then
                New("TextLabel", {
                    Size = UDim2.new(0,16,1,0),
                    Position = UDim2.new(1,-20,0,0),
                    BackgroundTransparency = 1,
                    Text = "вң“",
                    TextColor3 = T.AccentBright,
                    TextSize = 11,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Center,
                    Parent = Row,
                })
            end

            Row.MouseEnter:Connect(function()
                if tostring(item) ~= tostring(selected) then
                    TFast(Row, { BackgroundColor3 = T.SurfaceTop })
                    TFast(RowStroke, { Color = T.BorderLight })
                end
            end)
            Row.MouseLeave:Connect(function()
                if tostring(item) ~= tostring(selected) then
                    TFast(Row, { BackgroundColor3 = T.SurfaceHigh })
                    TFast(RowStroke, { Color = T.Border })
                end
            end)
            Row.MouseButton1Click:Connect(function()
                selected = tostring(item)
                Tween(Row, TI(0.06), { BackgroundColor3 = T.Accent })
                task.wait(0.08)
                BuildItems()
                pcall(act, selected)
            end)

            table.insert(itemRefs, Row)
        end
    end

    BuildItems()

    table.insert(self.Library.ControlRegistry, { Kind = "List", Root = Wrap, RootStroke = WrapStroke })
    table.insert(self.Elements, { Name = text, Instance = Wrap })

    return {
        GetValue    = function() return selected end,
        SetValue    = function(v, fire)
            selected = tostring(v)
            BuildItems()
            if fire then pcall(act, selected) end
        end,
        SetItems    = function(newItems, fire)
            items = newItems or {}
            selected = nil
            BuildItems()
            if fire then pcall(act, selected) end
        end,
        ClearSelect = function()
            selected = nil
            BuildItems()
        end,
    }
end

return ZyphoraLibrary
