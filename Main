-- Section Helper
local function InfoSection(label)
    local Wrap = New("Frame", {
        Size = UDim2.new(1, -PADDING, 0, 18),
        BackgroundTransparency = 1,
        Parent = InfoTab.ScrollBox,
    })
    New("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        Parent = Wrap,
    })
    local Chip = New("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = Wrap,
    })
    New("TextLabel", {
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = "  " .. string.upper(label) .. "  ",
        TextColor3 = T.TextMuted,
        TextSize = 8,
        Font = Enum.Font.GothamBold,
        Parent = Chip,
    })
end

-- Card Helper
local function CreateCard(parent, h, accentColor)
    accentColor = accentColor or T.Accent
    local Card = New("Frame", {
        Size = UDim2.new(1, -PADDING, 0, h or 64),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = parent,
    })
    Corner(Card, CARD_RADIUS)
    Stroke(Card, T.Border, 1)
    local Accent = New("Frame", {
        Size = UDim2.new(0, 3, 1, -20),
        Position = UDim2.new(0, 0, 0, 10),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = Card,
    })
    Corner(Accent, 2)
    return Card
end

