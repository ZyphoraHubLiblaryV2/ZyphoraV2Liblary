--  ICON SUPPORT
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local ICON_SUPPORT_URL = "https://raw.githubusercontent.com/ZyphoraHubLibrary/ZyphoraHubIconSupport/refs/heads/main/Icon"
local IconSupport = {}
pcall(function() IconSupport = loadstring(game:HttpGet(ICON_SUPPORT_URL))() end)

local function ResolveIcon(icon)
    if not icon then return nil end
    if typeof(icon) == "number" then return "rbxassetid://" .. tostring(icon) end
    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^http") then return icon end
        local fixed = IconSupport[icon]
            or IconSupport[icon:sub(1,1):upper() .. icon:sub(2)]
            or IconSupport[string.upper(icon)]
        if fixed then return fixed end
    end
    return nil
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  UTILITIES
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function Clamp255(n) return math.clamp(math.floor(tonumber(n) or 0), 0, 255) end
local function ColorToHex(c) return string.format("#%02X%02X%02X", Clamp255(c.R*255), Clamp255(c.G*255), Clamp255(c.B*255)) end
local function HexToColor(hex, fallback)
    if typeof(hex) ~= "string" then return fallback end
    hex = hex:gsub("#",""):gsub("0x","")
    if #hex ~= 6 then return fallback end
    local r,g,b = tonumber(hex:sub(1,2),16), tonumber(hex:sub(3,4),16), tonumber(hex:sub(5,6),16)
    if not r or not g or not b then return fallback end
    return Color3.fromRGB(r,g,b)
end
local function ParseImageLink(input)
    if typeof(input) ~= "string" then return nil end
    local s = input:gsub("%s+", "")
    if s == "" then return nil end

    if s:match("^rbxassetid://%d+$") then return s end
    if s:match("^%d+$") then return "rbxassetid://" .. s end

    local idFromUrl = s:match("roblox%.com/[^%s]-(%d+)")
    if idFromUrl then return "rbxassetid://" .. idFromUrl end

    if s:match("^https?://") and s:match("%.%a+$") then
        return s
    end

    local anyId = s:match("(%d+)")
    if anyId then return "rbxassetid://" .. anyId end

    return s
end
local function SanitizeName(name)
    name = tostring(name or ""):gsub("[%/%:*%?\"<>|]",""):gsub("%s+",""):gsub("[%+%^%$]","")
    return name == "" and "Profile" or name
end
local function FileExists(path) if isfile then local ok,r = pcall(isfile,path); return ok and r end return false end
local function EnsureFolder(path) if makefolder and not isfolder(path) then pcall(makefolder,path) end end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  UI HELPERS
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function New(class, props)
    local inst = Instance.new(class)
    for k,v in pairs(props) do
        if k ~= "Parent" and k ~= "Children" then
            pcall(function() inst[k] = v end)
        end
    end
    if props.Children then
        for _,child in ipairs(props.Children) do child.Parent = inst end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function Corner(parent, radius)
    return New("UICorner", { CornerRadius = UDim.new(0, radius or 8), Parent = parent })
end
local function Stroke(parent, color, thickness, transparency)
    return New("UIStroke", { Color = color, Thickness = thickness or 1, Transparency = transparency or 0, Parent = parent })
end
local function Gradient(parent, colors, rotation)
    local seq = {}
    for i,c in ipairs(colors) do
        table.insert(seq, ColorSequenceKeypoint.new((i-1)/(#colors-1), c))
    end
    return New("UIGradient", { Color = ColorSequence.new(seq), Rotation = rotation or 0, Parent = parent })
end
local function Pad(parent, padding)
    return New("UIPadding", {
        PaddingLeft = UDim.new(0, padding), PaddingRight = UDim.new(0, padding),
        PaddingTop = UDim.new(0, padding), PaddingBottom = UDim.new(0, padding),
        Parent = parent
    })
end

local TI = TweenInfo.new
local function Tween(inst, info, props)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end
local function TFast(inst, props) return Tween(inst, TI(0.15, Enum.EasingStyle.Quad), props) end
local function TSlow(inst, props) return Tween(inst, TI(0.3, Enum.EasingStyle.Quad), props) end
local function TSpring(inst, props) return Tween(inst, TI(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), props) end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  THEME DEFAULTS
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local DEFAULT_THEME = {
    -- Backgrounds (pure black, no purple tint)
    BG          = Color3.fromRGB(0,   0,   0),
    BGSecondary = Color3.fromRGB(8,   8,   8),
    BGTertiary  = Color3.fromRGB(14,  14,  14),
    Surface     = Color3.fromRGB(18,  18,  18),
    SurfaceHigh = Color3.fromRGB(24,  24,  24),
    SurfaceTop  = Color3.fromRGB(30,  30,  30),

    -- Borders (neutral grey, no blue/purple cast)
    Border      = Color3.fromRGB(40,  40,  40),
    BorderLight = Color3.fromRGB(58,  58,  58),

    -- Accent tetap purple biar masih ada identity
    Accent      = Color3.fromRGB(108,  59, 255),
    AccentBright= Color3.fromRGB(155, 110, 255),
    AccentDim   = Color3.fromRGB(75,   42, 180),
    AccentGlow  = Color3.fromRGB(108,  59, 255),

    -- Text
    Text        = Color3.fromRGB(255, 255, 255),
TextDim     = Color3.fromRGB(248, 248, 250),
TextMuted   = Color3.fromRGB(235, 235, 240),

    -- Status
    Success     = Color3.fromRGB(72, 200, 130),
    Error       = Color3.fromRGB(240, 75,  90),
    Warning     = Color3.fromRGB(255, 175,  55),

    -- Toggle
    ToggleOn    = Color3.fromRGB(108,  59, 255),
    ToggleOff   = Color3.fromRGB(22,  20, 35),
}

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  APPLY THEME
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:ApplyTheme(theme)
    theme = theme or self.Theme
    self.Theme = theme

    local T = theme

    if self._uiRefs then
        local R = self._uiRefs
        if R.MainFrame then
            R.MainFrame.BackgroundColor3 = T.BG
            if R.MainStroke then R.MainStroke.Color = T.Border end
        end
        if R.TopBar then
            R.TopBar.BackgroundColor3 = T.BGSecondary
        end
        if R.SidebarBg then
            R.SidebarBg.BackgroundColor3 = T.BGTertiary
        end
        if R.SidebarDiv then
            R.SidebarDiv.BackgroundColor3 = T.Border
        end
        if R.SearchBar then
            R.SearchBar.BackgroundColor3 = T.Surface
            if R.SearchBarStroke then R.SearchBarStroke.Color = T.Border end
            if R.SearchIcon then R.SearchIcon.ImageColor3 = T.TextMuted end
            if R.SearchBox then
                R.SearchBox.TextColor3 = T.Text
                R.SearchBox.PlaceholderColor3 = T.TextMuted
            end
        end
    end

    for _, tab in ipairs(self.Tabs or {}) do
        local isActive = tab == self.CurrentTab
        if tab.Button then
            tab.Button.BackgroundColor3 = isActive and T.SurfaceHigh or T.Surface
        end
        if tab.Label then
            tab.Label.TextColor3 = isActive and T.AccentBright or T.TextDim
        end
        if tab.Icon then
            tab.Icon.ImageColor3 = isActive and T.AccentBright or T.TextMuted
        end
        if tab.ActiveLine then
            tab.ActiveLine.BackgroundColor3 = isActive and T.Accent or Color3.fromRGB(0,0,0)
            tab.ActiveLine.BackgroundTransparency = isActive and 0 or 1
        end
    end

    for _, ref in ipairs(self.ControlRegistry or {}) do
        if not (ref.Root and ref.Root.Parent) then continue end
        ref.Root.BackgroundColor3 = T.Surface
        if ref.RootStroke then ref.RootStroke.Color = T.Border end
        if ref.Title then ref.Title.TextColor3 = T.Text end
        if ref.Icon then ref.Icon.ImageColor3 = T.TextMuted end
        if ref.Kind == "Button" then
            if ref.BtnText then ref.BtnText.TextColor3 = T.Text end
        elseif ref.Kind == "Toggle" then
            if ref.TText then ref.TText.TextColor3 = T.Text end
        elseif ref.Kind == "Dropdown" then
            ref.Root.BackgroundColor3 = T.Surface
            if ref.ValLabel then ref.ValLabel.TextColor3 = T.TextDim end
        elseif ref.Kind == "Input" then
            ref.Root.BackgroundColor3 = T.Surface
            if ref.Box then
                ref.Box.TextColor3 = T.Text
                ref.Box.PlaceholderColor3 = T.TextMuted
            end
        elseif ref.Kind == "Label" then
            ref.Root.BackgroundColor3 = T.BGSecondary
            if ref.Sub then ref.Sub.TextColor3 = T.TextMuted end
        elseif ref.Kind == "Slider" then
            if ref.Track then ref.Track.BackgroundColor3 = T.SurfaceHigh end
        elseif ref.Kind == "Section" then
            if ref.Line then ref.Line.BackgroundColor3 = T.Border end
            if ref.Txt then ref.Txt.TextColor3 = T.TextMuted end
            end
         end
            if self._bgPassthroughActive then
        self:SetBackgroundPassthrough(true)
    end
    
    -- Update TitleGlow saat theme berubah
if self._uiRefs.TitleGlow then
    self._uiRefs.TitleGlow.TextColor3 = self._glowColor or T.AccentBright
    if self._glowRunning then
        self._glowRunning = false
        task.wait(0.1)
        self:StartTitleGlow()
    end
end

end

-- Tambahkan function ini, panggil saat background diterapkan/dihapus
function ZyphoraLibrary:SetBackgroundPassthrough(active)
    local trans = active and 0.55 or 0

    if self._uiRefs.SidebarBg then
        self._uiRefs.SidebarBg.BackgroundTransparency = trans
    end
    if self._uiRefs.TopBar then
        self._uiRefs.TopBar.BackgroundTransparency = trans
    end
    if self._uiRefs.SearchBar then
        self._uiRefs.SearchBar.BackgroundTransparency = trans
    end

    -- Semua card/control di dalam tab (Button, Toggle, Label, dst)
    for _, ref in ipairs(self.ControlRegistry or {}) do
        if ref.Root and ref.Root.Parent then
            ref.Root.BackgroundTransparency = trans
        end
    end

    self._bgPassthroughActive = active
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  PROFILE SYSTEM
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:RefreshSaveProfiles()
    if not self.SaveDropdown then return end
    local list = {}
    if listfiles and isfolder and isfolder(self.SaveFolder) then
        for _, file in ipairs(listfiles(self.SaveFolder)) do
            if file:sub(-5) == ".json" then
                local name = file:match("([^/%\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
    end
    table.sort(list, function(a,b) return a:lower() < b:lower() end)
    if #list == 0 then list = { "Tidak ada profile" } end
    if self.SaveDropdown.SetOptions then
        self.SaveDropdown:SetOptions(list, list[1], false)
    end
end

function ZyphoraLibrary:RefreshPlayerDropdown(dropdownRef)
    if not dropdownRef then return end
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        table.insert(list, plr.Name)
    end
    table.sort(list)
    if #list == 0 then list = { "Tidak ada player" } end
    if dropdownRef.SetOptions then
        dropdownRef:SetOptions(list, list[1], false)
    end
end

function ZyphoraLibrary:SaveProfile(profileName)
    if not writefile then
        self:Notify("Gagal", "Executor tidak support writefile.", "error")
        return false
    end

    EnsureFolder(self.SaveFolder)

    local safe = SanitizeName(profileName)

    -- GABUNGKAN SEMUA DATA DI SATU TABLE
    local data = {
        Theme = {},
        Toggles = self.ToggleStates or {},
        Sliders = {},
        Watermark = {},
        BigWatermark = self._wmMode or "Center",
        -- TITLE GLOW SAVE
        GlowMode = self._glowMode or "Detak Jantung",
        GlowSpeed = self._glowSpeed or 1.0,
        GlowIntensity = self._glowIntensity or 0.8,
        GlowColor = ColorToHex(self._glowColor or self.Theme.AccentBright),
        GlowVariant = self._glowVariant or "Normal",
    }

    -- Theme
    for k,v in pairs(self.Theme) do
        if typeof(v) == "Color3" then
            data.Theme[k] = ColorToHex(v)
        end
    end

    -- Slider Save
    if self.SliderRegistry then
        for name,obj in pairs(self.SliderRegistry) do
            data.Sliders[name] = obj.Value
        end
    end

    -- WM Save
    if self.Watermark then
        data.Watermark.Position = {
            XScale = self.Watermark.Position.X.Scale,
            XOffset = self.Watermark.Position.X.Offset,
            YScale = self.Watermark.Position.Y.Scale,
            YOffset = self.Watermark.Position.Y.Offset,
        }
    end

    writefile(
        self.SaveFolder .. "/" .. safe .. ".json",
        HttpService:JSONEncode(data)
    )

    self:Notify("Profile Disimpan", safe, "success")
    self:RefreshSaveProfiles()

    return true
end

function ZyphoraLibrary:DeleteProfile(profileName)
    if not delfile then self:Notify("Gagal", "Executor tidak support delfile.", "error"); return false end
    local safe = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safe .. ".json"
    if not FileExists(path) then self:Notify("Gagal", "Profile tidak ditemukan.", "error"); return false end
    local ok = pcall(delfile, path)
    if not ok then self:Notify("Gagal", "Profile gagal dihapus.", "error"); return false end
    self:Notify("Profile Dihapus", '"' .. safe .. '" berhasil dihapus.', "error")
    self:RefreshSaveProfiles()
    return true
end

function ZyphoraLibrary:LoadProfile(profileName)
    if not readfile then
        self:Notify("Gagal", "Executor tidak support readfile.", "error")
        return false
    end

    local safe = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safe .. ".json"

    if not FileExists(path) then
        self:Notify("Gagal", "Profile tidak ditemukan.", "error")
        return false
    end

    local raw = readfile(path)
    local data = HttpService:JSONDecode(raw)

    -- Theme
    if data.Theme then
        for k,v in pairs(data.Theme) do
            self.Theme[k] = HexToColor(v, self.Theme[k])
        end
    end

    -- Toggle
    if data.Toggles then
        for name,val in pairs(data.Toggles) do
            local reg = self.ToggleRegistry[name]
            if reg and reg.SetState then
                reg.SetState(val, true)
            end
        end
    end

    -- Slider
    if data.Sliders and self.SliderRegistry then
        for name,val in pairs(data.Sliders) do
            local reg = self.SliderRegistry[name]
            if reg and reg.SetValue then
                reg.SetValue(val, true)
            end
        end
    end

    -- Watermark Position
    if data.Watermark and self.Watermark then
        local p = data.Watermark.Position

        if p then
            self.Watermark.Position = UDim2.new(
                p.XScale,
                p.XOffset,
                p.YScale,
                p.YOffset
            )
        end
    end
    
    if data.BigWatermark and self.UpdateBigWM then
        self.UpdateBigWM(data.BigWatermark)
    end
    
    -- LOAD TITLE GLOW SETTINGS
if data.GlowMode then self._glowMode = data.GlowMode end
if data.GlowSpeed then self._glowSpeed = data.GlowSpeed end
if data.GlowIntensity then self._glowIntensity = data.GlowIntensity end
if data.GlowColor then self._glowColor = HexToColor(data.GlowColor, self.Theme.AccentBright) end
if data.GlowVariant then self._glowVariant = data.GlowVariant end

-- Restart glow
if self._glowRunning then
    self._glowRunning = false
    task.wait(0.1)
end
self:StartTitleGlow()

-- Update UI elements
if self._glowDrop and self._glowDrop.SetValue then
    self._glowDrop:SetValue(self._glowMode, false)
end
if self._glowVariantDrop and self._glowVariantDrop.SetValue then
    self._glowVariantDrop:SetValue(self._glowVariant, false)
end
if self._glowSpeedSlider and self._glowSpeedSlider.SetValue then
    self._glowSpeedSlider:SetValue(self._glowSpeed * 10, false)
end
if self._glowIntensitySlider and self._glowIntensitySlider.SetValue then
    self._glowIntensitySlider:SetValue(self._glowIntensity * 10, false)
end
if self._glowColorInput then
    self._glowColorInput:SetValue(ColorToHex(self._glowColor))
end

    self:ApplyTheme(self.Theme)

    self:Notify("Profile Dimuat", safe, "success")

    return true
end

