     -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  MINIMIZE FUNCTION (FIXED - FULL)
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function MinimizeWindow()
    if self.Hidden then return end

    self.Minimized = not self.Minimized

    -- simpan ukuran normal HANYA saat pertama kali minimize
    self._savedSize = self.LastSize or MainFrame.Size

    local targetSize

    if self.Minimized then
        targetSize = UDim2.new(
            self._savedSize.X.Scale,
            self._savedSize.X.Offset,
            0,
            40
        )
    else
        targetSize = self._savedSize
    end

    -- pakai 1 sistem tween saja
    TweenService:Create(
        MainFrame,
        TI(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        { Size = targetSize }
    ):Play()

    local show = not self.Minimized

 -- вң… Sembunyikan/tampilkan custom background & gradient
if self._uiRefs.CustomBackground then
    self._uiRefs.CustomBackground.Visible = show
end
    if self._uiRefs.CustomBackgroundGradient then
        local gradVisible = self._uiRefs.CustomBackgroundGradient.Visible
        self._uiRefs.CustomBackgroundGradient.Visible = show and gradVisible
    end

    -- вң… Sembunyikan/tampilkan ResizeHandle
    if ResizeHandle then
        ResizeHandle.Visible = show
    end

    -- вң… Sembunyikan FrameGlow juga
    if FrameGlow then
        FrameGlow.Visible = show
    end

    task.delay(self.Minimized and 0 or 0.15, function()
        if self._uiRefs.SidebarBg then self._uiRefs.SidebarBg.Visible = show end
        if self._uiRefs.SidebarDiv then self._uiRefs.SidebarDiv.Visible = show end
        if self.Sidebar then self.Sidebar.Visible = show end
        if self._uiRefs.SearchBar then self._uiRefs.SearchBar.Visible = show end
        if self.ContentHolder then self.ContentHolder.Visible = show end

        for _, tab in ipairs(self.Tabs) do
            if tab.Button then
                tab.Button.Visible = show
            end

            if tab.ScrollBox then
                tab.ScrollBox.Visible = show and tab == self.CurrentTab
            end
        end
    end)
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  HIDE / SILUMAN FUNCTION (FIXED - FULL)
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function ToggleHideWindow()
    self.Hidden = not self.Hidden

    -- simpan ukuran pertama kali (kalau belum ada)
    if not self.LastSize then
        self.LastSize = MainFrame.Size
    end

    if self.Hidden then
        -- вң… Sembunyikan semua elemen visual
        if self._uiRefs.CustomBackground then
            self._uiRefs.CustomBackground.Visible = false
        end
        if self._uiRefs.CustomBackgroundGradient then
            self._uiRefs.CustomBackgroundGradient.Visible = false
        end
        if ResizeHandle then
            ResizeHandle.Visible = false
        end
        if FrameGlow then
            FrameGlow.Visible = false
        end

        local tw = TweenService:Create(
            MainFrame,
            TI(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {
                BackgroundTransparency = 1,
                Size = UDim2.new(self.LastSize.X.Scale, self.LastSize.X.Offset, 0, 0)
            }
        )

        tw:Play()
        tw.Completed:Once(function()
            MainFrame.Visible = false
        end)

    else
    MainFrame.Visible = true
    MainFrame.BackgroundTransparency = 1

    local target = self.Minimized
        and UDim2.new(self.LastSize.X.Scale, self.LastSize.X.Offset, 0, 40)
        or self.LastSize

    TSpring(MainFrame, {
        BackgroundTransparency = 0,
        Size = target
    })

    task.delay(0.15, function()
        -- вң… FIX: cek state aktif yang tersimpan, bukan unconditional true
        if self._uiRefs.CustomBackground then
            self._uiRefs.CustomBackground.Visible = (self._uiRefs._customBgActive == true) and (not self.Minimized)
        end
        if self._uiRefs.CustomBackgroundGradient then
            local gradToggle = self._uiRefs._gradToggleState
            self._uiRefs.CustomBackgroundGradient.Visible = (gradToggle or false) and (not self.Minimized)
        end
        if ResizeHandle then
            ResizeHandle.Visible = not self.Minimized
        end
        if FrameGlow then
            FrameGlow.Visible = not self.Minimized
        end

        -- вң… FIX: jangan paksa true, ikuti state Minimized
        local showFull = not self.Minimized
        if self._uiRefs.SidebarBg then self._uiRefs.SidebarBg.Visible = showFull end
        if self._uiRefs.SidebarDiv then self._uiRefs.SidebarDiv.Visible = showFull end
        if self.Sidebar then self.Sidebar.Visible = showFull end
        if self._uiRefs.SearchBar then self._uiRefs.SearchBar.Visible = showFull end
        if self.ContentHolder then self.ContentHolder.Visible = showFull end

        for _, tab in ipairs(self.Tabs) do
            if tab.Button then
                tab.Button.Visible = showFull
            end
            if tab.ScrollBox then
                tab.ScrollBox.Visible = showFull and tab == self.CurrentTab
            end
        end
    end)
end
