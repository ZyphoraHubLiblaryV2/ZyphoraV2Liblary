local function UpdateBigWM(mode)
    self._wmMode = mode

    if mode == "Left" then
        WMText.AnchorPoint = Vector2.new(0, 0.5)
        WMText.Position = UDim2.new(0, 0, 0.5, 0)

    elseif mode == "Center" then
        WMText.AnchorPoint = Vector2.new(0.5, 0.5)
        WMText.Position = UDim2.new(0.5, 0, 0.5, 0)

    elseif mode == "Right" then
        WMText.AnchorPoint = Vector2.new(1, 0.5)
        WMText.Position = UDim2.new(1, 0, 0.5, 0)

    -- вҶҗ TAMBAHAN BARU
    elseif mode == "TopLeft" then
        WMText.AnchorPoint = Vector2.new(0, 0)
        WMText.Position = UDim2.new(0, 0, 0, 0)

    elseif mode == "TopRight" then
        WMText.AnchorPoint = Vector2.new(1, 0)
        WMText.Position = UDim2.new(1, 0, 0, 0)

    elseif mode == "BottomLeft" then
        WMText.AnchorPoint = Vector2.new(0, 1)
        WMText.Position = UDim2.new(0, 0, 1, 0)

    elseif mode == "BottomRight" then
        WMText.AnchorPoint = Vector2.new(1, 1)
        WMText.Position = UDim2.new(1, 0, 1, 0)
    end
end

UpdateBigWM("Center")
self.UpdateBigWM = UpdateBigWM

