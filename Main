    local function GetReply(msg)
        msg = string.lower(msg)
        for _, entry in ipairs(KB) do
            for _, key in ipairs(entry.keys) do
                if string.find(msg, key) then return entry.ans end
            end
        end
        return "Hmm, aku belum punya info tentang itu рҹӨ”\nCoba tanya hal lain tentang Zyphora Hub!"
    end

