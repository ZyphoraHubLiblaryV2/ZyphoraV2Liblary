-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  TITLE GLOW ENGINE (REMAKE TOTAL V2)
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function ZyphoraLibrary:StartTitleGlow()
    if self._glowRunning then return end
    self._glowRunning = true

    local titleGlow = self._uiRefs.TitleGlow
    if not titleGlow then self._glowRunning = false; return end

    local baseText = titleGlow.Text
    local basePos = titleGlow.Position
    local baseSize = titleGlow.TextSize
    local baseColor = self._glowColor or self.Theme.AccentBright

    titleGlow.TextColor3 = baseColor

    for _, child in ipairs(titleGlow:GetChildren()) do
        if child:IsA("UIStroke") or child:IsA("UIGradient") then
            child:Destroy()
        end
    end

    local glowStroke = Instance.new("UIStroke")
    glowStroke.Color = baseColor
    glowStroke.Thickness = 1
    glowStroke.Transparency = 0.4
    glowStroke.LineJoinMode = Enum.LineJoinMode.Round
    glowStroke.Parent = titleGlow

    local sweepGradient = Instance.new("UIGradient")
    sweepGradient.Color = ColorSequence.new(baseColor)
    sweepGradient.Transparency = NumberSequence.new(1)
    sweepGradient.Enabled = false
    sweepGradient.Parent = titleGlow

    local function ResetVisual()
        titleGlow.TextSize = baseSize
        titleGlow.Position = basePos
        titleGlow.Text = baseText
        titleGlow.TextXAlignment = Enum.TextXAlignment.Left
        titleGlow.TextTransparency = 0
        sweepGradient.Enabled = false
    end

    local VARIANT_MULT = {
        Soft    = 0.5,
        Normal  = 1.0,
        Neon    = 1.3,
        Extreme = 1.8,
        Retro   = 0.7,
    }

    self._glowTask = task.spawn(function()
        local t = 0

        while self._glowRunning and titleGlow and titleGlow.Parent do
            local mode      = self._glowMode or "Pulse"
            local speed     = self._glowSpeed or 1.0
            local intensity = self._glowIntensity or 0.8
            local color     = self._glowColor or self.Theme.AccentBright
            local mult      = VARIANT_MULT[self._glowVariant] or 1.0

            t = t + (0.016 * speed)
            ResetVisual()
            titleGlow.TextColor3 = color

           -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            -- MODE 1: PULSE
            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            if mode == "Pulse" then
                local wave = (math.sin(t * 2) + 1) / 2
                local glowVal = math.clamp(0.15 + wave * intensity * mult, 0, 1)

                glowStroke.Color = color
                glowStroke.Transparency = 0.85 - glowVal * 0.7
                glowStroke.Thickness = 1 + glowVal * 6          -- вҳ… dibesarkan dari 3 вҶ’ 6
                titleGlow.TextSize = baseSize + glowVal * 4      -- вҳ… BARU: ukuran ikut membesar
                titleGlow.TextTransparency = math.clamp(0.25 - glowVal * 0.2, 0, 0.5)

            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            -- MODE 2: SWEEP (tetap sama, ini sudah benar/beda)
            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            elseif mode == "Sweep" then
                -- (tidak diubah, sudah bekerja baik)
                local cycle = (t * 0.5 * speed) % 2
                local sweepPos = math.clamp(cycle <= 1 and cycle or 2 - cycle, 0, 1)
                local bandWidth = 0.18 / mult

                local p0 = math.clamp(sweepPos - bandWidth, 0, 1)
                local p1 = sweepPos
                local p2 = math.clamp(sweepPos + bandWidth, 0, 1)
                if p0 >= p1 then p0 = math.max(p1 - 0.001, 0) end
                if p2 <= p1 then p2 = math.min(p1 + 0.001, 1) end

                sweepGradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, color),
                    ColorSequenceKeypoint.new(p0, color),
                    ColorSequenceKeypoint.new(p1, Color3.new(1,1,1)),
                    ColorSequenceKeypoint.new(p2, color),
                    ColorSequenceKeypoint.new(1, color),
                })
                sweepGradient.Transparency = NumberSequence.new(0)
                sweepGradient.Enabled = true

                glowStroke.Transparency = 0.7
                glowStroke.Thickness = 1
                titleGlow.TextTransparency = 0.05
                titleGlow.TextColor3 = Color3.new(1,1,1)

            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            -- MODE 3: GLITCH вҖ” DIBESARKAN DRASTIS
            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            elseif mode == "Glitch" then
                local shakeAmount = 6 * intensity * mult        -- вҳ… dari 1.5 вҶ’ 6 (4x lebih besar)
                local offsetX = math.noise(t * 15, 0) * shakeAmount
                local offsetY = math.noise(0, t * 15) * shakeAmount

                titleGlow.Position = UDim2.new(
                    basePos.X.Scale, basePos.X.Offset + offsetX,
                    basePos.Y.Scale, basePos.Y.Offset + offsetY
                )

                local flicker = (math.floor(t * 12) % 4 == 0) and 0.7 or 0.0  -- вҳ… flicker lebih sering & lebih kontras

                glowStroke.Color = color
                glowStroke.Transparency = 0.3
                glowStroke.Thickness = 2
                titleGlow.TextTransparency = flicker

                -- вҳ… BARU: kadang teks split warna RGB (efek glitch khas)
                if math.floor(t * 8) % 5 == 0 then
                    titleGlow.TextColor3 = Color3.fromRGB(255, 50, 50)
                else
                    titleGlow.TextColor3 = color
                end

            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            -- MODE 4: RAINBOW вҖ” DIPERCEPAT DRASTIS
            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            elseif mode == "Rainbow" then
                local hue = (t * 0.5 * speed) % 1               -- вҳ… dari 0.12 вҶ’ 0.5 (4x lebih cepat)
                local rainbowColor = Color3.fromHSV(hue, 1, 1)   -- вҳ… saturation dari 0.85 вҶ’ 1 (lebih jenuh/terang)

                glowStroke.Color = rainbowColor
                glowStroke.Transparency = 0.3                     -- вҳ… lebih solid, dari ~0.4 вҶ’ 0.3
                glowStroke.Thickness = 3 + intensity * mult * 2   -- вҳ… lebih tebal
                titleGlow.TextTransparency = 0.05
                titleGlow.TextColor3 = rainbowColor

            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            -- FALLBACK: MATI
            -- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            else
                glowStroke.Transparency = 1
                glowStroke.Thickness = 0
                titleGlow.TextTransparency = 0.15
            end

            task.wait(0.016)
        end

        if titleGlow and titleGlow.Parent then
            ResetVisual()
            titleGlow.TextColor3 = baseColor
        end
    end)
end

-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
